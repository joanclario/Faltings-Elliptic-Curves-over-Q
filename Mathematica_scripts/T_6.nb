          RowBox[{"[", "1", "]"}], "]"}], "/", "48"}]}], ",", 
       RowBox[{"\"\<c6=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "/", "864"}]}]}], "}"}], "]"}], ";",
     "\[IndentingNewLine]", " ", 
    RowBox[{"Return", "[", "M", "]"}]}], ")"}]}]], "Input",
