}, Closed]],

Cell[CellGroupData[{

Cell["Twist", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.9906679078802147`*^9}},ExpressionUUID->"a4fad80b-5e8c-4f7c-ac22-\
69d2e2363004"],

Cell["\<\
Twist[{c4, c6, Delta}, s]
 Applies the standard scaling transformation to the invariants of an elliptic \
curve.
 Under a change of variables with scaling factor s, the invariants transform as
    c4    -> c4/s^4,
    c6    -> c6/s^6,
    Delta -> Delta/s^12.
 The resulting expressions are power - expanded, refined, and factored.\
\>", "Text",
 CellChangeTimes->{
  3.9906684897516203`*^9, {3.9906685763156033`*^9, 
   3.99066859000504*^9}},ExpressionUUID->"e82e227a-0e93-4da2-81d4-\
defd5cc1b522"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Twist", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"c4_", ",", "c6_", ",", "Delta_"}], "}"}], ",", "s_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"PowerExpand", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"c4", "/", 
        RowBox[{"s", "^", "4"}]}], ",", 
       RowBox[{"c6", "/", 
        RowBox[{"s", "^", "6"}]}], ",", 
       RowBox[{"Delta", "/", 
        RowBox[{"s", "^", "12"}]}]}], "}"}], "]"}], "//", "Refine"}], "//", 
   "Factor"}]}]], "Input",
 CellChangeTimes->{{3.8862536998964443`*^9, 3.886253769114563*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"9cea5e6a-50f4-4f68-bcb5-eb56bf4e543a"]
}, Closed]],

Cell[CellGroupData[{

Cell["CuentaP2 ", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.9906679276567574`*^9}},ExpressionUUID->"39422a30-9d91-4ba5-94fc-\
26304075b048"],

Cell["\<\
CuentaP2[c4, c6, m]
Computes the congruence expression
   (c6/3^3)^2 + 2 - 3 c4/3^2
after the substitution t = 3^m u.
The expression is power - expanded, refined, factored, and then reduced \
modulo 9.
This function is intended to check a local congruence condition at p = 3.\
\[LineSeparator]Condition P2 in Papadopoulus\[CloseCurlyQuote]s paper for p=3 \
(Section II.2, Tableaus II)\
\>", "Text",
 CellChangeTimes->{{3.990668254622575*^9, 3.990668255780031*^9}, 
   3.990668492990816*^9, {3.990668598544017*^9, 3.990668605585143*^9}, {
   3.990672598122566*^9, 3.990672625986929*^9}, {3.990672681549316*^9, 
   3.990672696935503*^9}, {3.990672770157649*^9, 
   3.990672775668046*^9}},ExpressionUUID->"b429efd3-6192-4a5f-98a4-\
e20d54c4b10e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CuentaP2", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c6", "/", 
            RowBox[{"3", "^", "3"}]}], ")"}], "^", "2"}], "+", "2", "-", 
         RowBox[{"3", " ", 
          RowBox[{"c4", "/", 
           RowBox[{"3", "^", "2"}]}]}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"3", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "9"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.990672383534123*^9},
 CellLabel->"In[8]:=",ExpressionUUID->"2c442c55-a8bd-4c1a-b893-a7882b1efd56"]
}, Closed]],

Cell[CellGroupData[{

Cell["CuentaP5", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.990667934470553*^9}},ExpressionUUID->"0b2f6187-a2c3-4c6c-ab73-\
dbdee06cb5ed"],

Cell["\<\
CuentaP5[c4, c6, m]
Computes the congruence expression
      (c6/3^6)^2 + 2 - 3 c4/3^4
after the substitution t = 3^m u.
The expression is power - expanded, refined, factored, and then reduced \
modulo 9.
This function is intended to check a related local congruence condition at p \
= 3.
Condition P5 in Papadopoulus\[CloseCurlyQuote]paper for p=3 (Section II.2, \
Tableaus II)\
\>", "Text",
 CellChangeTimes->{
  3.990668495850008*^9, {3.990668608689356*^9, 3.990668629771914*^9}, {
   3.990672631848387*^9, 3.990672635188414*^9}, 3.990672703406727*^9, {
   3.9906727651735888`*^9, 
   3.990672766140173*^9}},ExpressionUUID->"a32f3c8f-332a-4d76-b7eb-\
75696c599708"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CuentaP5", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c6", "/", 
            RowBox[{"3", "^", "6"}]}], ")"}], "^", "2"}], "+", "2", "-", 
         RowBox[{"3", " ", 
          RowBox[{"c4", "/", 
           RowBox[{"3", "^", "4"}]}]}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"3", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "9"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.99067240018237*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"6452796c-8c95-4bef-8b28-f41f9c0c2814"]
}, Closed]],

Cell[CellGroupData[{

Cell["PolandLemma22", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, 
   3.990667946386627*^9},ExpressionUUID->"607e71e5-8101-40d0-a913-\
932745216878"],

Cell["\<\
PolandLemma22[c6, m, n]
Computes c6/2^n after the substitution t = 2^m u.
The expression is power - expanded, refined, factored, and reduced modulo 4.
This appears to be designed to verify a congruence condition related to Lemma \
2.2 in Browkin & Davies\[CloseCurlyQuote] paper.\
\>", "Text",
 CellChangeTimes->{
  3.990668499775419*^9, {3.990668633753881*^9, 3.990668643091579*^9}, {
   3.9906727441943703`*^9, 
   3.99067275898619*^9}},ExpressionUUID->"c03ff20d-fe0e-4cc4-82ca-\
4575d0122673"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PolandLemma22", "[", 
   RowBox[{"c6_", ",", "m_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{"c6", "/", 
         RowBox[{"2", "^", "n"}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"2", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "4"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.886303098200499*^9, 3.886303176740327*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"032f4202-24ee-411f-b24a-cf9741b54211"]
}, Closed]],

Cell[CellGroupData[{

Cell["Vision", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, 
   3.990667957557056*^9, {3.99067246543884*^9, 
   3.990672466608118*^9}},ExpressionUUID->"46f627f6-bc8f-42e0-805b-\
68ab0352bb0e"],

Cell["\<\
Vision[P, u]
Factors the polynomial or expression P.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
 This is a diagnostic helper function for inspecting the coefficients of the \
factors of P.
  The function uses FactorList, which is safer than applying List directly to \
Factor[P], because it avoids splitting irreducible sums into terms.\
\>", "Text",
 CellChangeTimes->{
  3.990668503318449*^9, {3.9906686471060133`*^9, 3.9906686674900217`*^9}, {
   3.990672476810256*^9, 
   3.990672477733142*^9}},ExpressionUUID->"d24fea6b-6029-4c44-8e84-\
21521545ddc0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Vision", "[", 
   RowBox[{"P_", ",", "u_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"L", "=", 
     RowBox[{"Factor", "[", "P", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "<=", 
       RowBox[{"Length", "@", "L"}]}], ",", 
      RowBox[{"i", "++"}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"i", ",", "\"\< <---> \>\"", ",", 
         RowBox[{"L", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", " ", 
       RowBox[{"Print", "@", 
        RowBox[{"MatrixForm", "@", 
         RowBox[{"Transpose", "@", 
          RowBox[{"{", 
           RowBox[{"CoefficientList", "[", 
            RowBox[{
             RowBox[{"L", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", "u"}], "]"}], 
           "}"}]}]}]}]}]}], "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886401267026865*^9, 3.8864012679454947`*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"c363af7f-e2c9-45e4-bff4-733eaad13dd1"]
}, Closed]],

Cell[CellGroupData[{

Cell["VisionMod", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990672485630422*^9, 
   3.990672486506579*^9}},ExpressionUUID->"3c161c31-d67d-42cf-a19f-\
98f3bce35757"],

Cell["\<\
AyudaMod[P, u, p]
First reduces P modulo p and factors the result.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
This is useful for studying the factorization and coefficients of P modulo p.\
\
\>", "Text",
 CellChangeTimes->{
  3.990668506896264*^9, {3.990668672078745*^9, 
   3.990668680314468*^9}},ExpressionUUID->"0b31f114-0560-48d6-88d3-\
631e46a1b539"],

Cell[BoxData[
 RowBox[{
  RowBox[{"VisionMod", "[", 
   RowBox[{"P_", ",", " ", "u_", ",", " ", "p_"}], "]"}], " ", ":=", "\n", 
  "  ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"L", ",", " ", "Q", ",", " ", "i"}], "}"}], ",", "\n", "    ", 
    RowBox[{
     RowBox[{"Q", " ", "=", " ", 
      RowBox[{"PolynomialMod", "[", 
       RowBox[{"P", ",", " ", "p"}], "]"}]}], ";", "\n", "    ", 
     RowBox[{"L", " ", "=", " ", 
      RowBox[{
       RowBox[{"FactorList", "[", "Q", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"2", " ", ";;"}], ",", " ", "1"}], "]"}], "]"}]}], ";", "\n",
      "    ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"L", " ", "===", " ", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"L", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{"Factor", "[", "Q", "]"}], "}"}]}]}], "  ", "]"}], ";", "\n",
      "    ", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", " ", "=", " ", "1"}], ",", " ", 
       RowBox[{"i", " ", "<=", " ", 
        RowBox[{"Length", "[", "L", "]"}]}], ",", " ", 
       RowBox[{"i", "++"}], ",", "  ", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"i", ",", " ", "\"\< <---> \>\"", ",", " ", 
          RowBox[{"L", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", " ", "@", " ", 
         RowBox[{"MatrixForm", " ", "@", " ", 
          RowBox[{"Transpose", " ", "@", " ", 
           RowBox[{"{", 
            RowBox[{"CoefficientList", "[", 
             RowBox[{
              RowBox[{"L", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", " ", "u"}], "]"}], 
            "}"}]}]}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], 
   "\[IndentingNewLine]", " ", "]"}]}]], "Input",
 CellChangeTimes->{{3.9906724917628393`*^9, 3.990672529367728*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"d7d421b6-8479-4497-9d66-89badba76969"]
}, Closed]],

Cell[CellGroupData[{

Cell["powerPrime", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, 
   3.990668002047792*^9},ExpressionUUID->"ab40297d-1521-47ae-8dea-\
3d82d9c1ba49"],

Cell["\<\
powerPrime[n, p]
Computes the exponent of the prime p in the prime factorization of n.
 In other words, it returns the p - adic valuation v_p (n).\
\>", "Text",
 CellChangeTimes->{
  3.990668512216362*^9, {3.990668685634695*^9, 
   3.990668705264998*^9}},ExpressionUUID->"78510592-eb91-4dd3-bbbc-\
d3a15162e6f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"powerPrime", "[", 
   RowBox[{"n_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "f", "}"}], ",", 
    RowBox[{
     RowBox[{"f", "=", 
      RowBox[{"FactorInteger", "[", "n", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"k", "=", 
      RowBox[{"Cases", "[", 
       RowBox[{"f", ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"p", ",", "k_"}], "}"}], "\[RuleDelayed]", "k"}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"k", "\[Equal]", 
        RowBox[{"{", "}"}]}], ",", "0", ",", 
       RowBox[{"k", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8872517996742373`*^9, 3.887251812890751*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"3616a629-d197-4470-9a90-c9a6f1444715"]
}, Closed]],

Cell[CellGroupData[{

Cell["pIntegralModel", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990668014657935*^9, 
   3.990668018277915*^9}},ExpressionUUID->"ca619a03-fc7b-4f95-8283-\
1c443ca818b1"],

Cell["\<\
pIntegralModel[M, p]
Checks whether the Weierstrass coefficients associated to the invariant \
triple M are p - integral.
The input M is expected to be a list of the form
      M = {c4, c6, Delta}.
The corresponding Weierstrass coefficients are computed as
    a4 = -M[[1]]/48,
    a6 = -M[[2]]/864.
 The function then checks whether the denominators of a4 and a6 are divisible \
by p.
 It returns True if both coefficients are p - integral.
 If at least one coefficient is not p - integral, it prints {a4, a6} and \
returns False.\
\>", "Text",
 CellChangeTimes->{
  3.990668515099354*^9, {3.990668711294724*^9, 
   3.990668748113006*^9}},ExpressionUUID->"2f86d189-efd6-418b-a883-\
654d429fb2ba"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pIntegralModel", "[", 
   RowBox[{"M_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"F", ",", "L"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"F", "=", 
      RowBox[{"Factor", "@", 
       RowBox[{"Refine", "@", 
        RowBox[{"PowerExpand", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{"M", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], "/", "48"}], ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"M", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "/", "864"}]}], "}"}], 
         "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"L", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"powerPrime", "[", 
         RowBox[{
          RowBox[{"Denominator", "@", 
           RowBox[{"F", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", "p"}], "]"}], ",", 
        RowBox[{"powerPrime", "[", 
         RowBox[{
          RowBox[{"Denominator", "@", 
           RowBox[{"F", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", "p"}], "]"}]}], "}"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"L", "\[Equal]", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], ",", "True", ",", " ", 
       RowBox[{
        RowBox[{"Print", "[", "L", "]"}], ";", "False"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.8872080410140142`*^9, 3.8872081043152437`*^9}, {
  3.887208226545286*^9, 3.887208239810857*^9}, {3.887208283031227*^9, 
  3.887208385892682*^9}, {3.8872514232683887`*^9, 3.887251491833002*^9}, {
  3.887251557834517*^9, 3.8872515674537363`*^9}, {3.887251831685504*^9, 
  3.8872518580315332`*^9}, {3.887251912020729*^9, 3.8872520142963457`*^9}, {
  3.887252068933837*^9, 3.887252093188457*^9}, {3.887252292695537*^9, 
  3.887252335330195*^9}, {3.9906725807675543`*^9, 3.9906725819134483`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"4b5ae3e9-4356-4961-8447-a3ddb440867e"]
}, Closed]],

Cell[CellGroupData[{

Cell["aInvariants", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990668014657935*^9, 
   3.990668018277915*^9}, 
   3.991049666438471*^9},ExpressionUUID->"edb8b284-e9ed-4ca0-93ea-\
a35e7dc09a41"],

Cell["\<\
aInvariants[c4,c6]
Given the c-invariants c4 and c6 of an elliptic curve E,   
this function returns the corresponding coefficients {a4, a6}  of the short \
Weierstrass equation 
  y^2 = x^3 + a4 x + a6
using the relations
   a4 = -c4/48,
   a6 = -c6/864.\
\>", "Text",
 CellChangeTimes->{
  3.990668515099354*^9, {3.990668711294724*^9, 3.990668748113006*^9}, {
   3.991049684125448*^9, 3.991049688373836*^9}, {3.99104991174494*^9, 
   3.9910500573305283`*^9}, {3.991050235804418*^9, 
   3.991050278812703*^9}},ExpressionUUID->"ea3a9b35-9e30-4a4a-9674-\
b032c3963530"],

Cell[BoxData[
 RowBox[{
  RowBox[{"aInvariants", "[", 
   RowBox[{"c4_", ",", "c6_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "c4"}], "/", "48"}], ",", 
    RowBox[{
     RowBox[{"-", "c6"}], "/", "864"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.991049681538488*^9, 3.991049758442471*^9}, {
  3.9910500946855*^9, 3.9910500974481287`*^9}, {3.991050241722801*^9, 
  3.991050245677408*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"b02967ed-a550-4895-be04-5123b1328302"]
}, Closed]]
}, Closed]],

