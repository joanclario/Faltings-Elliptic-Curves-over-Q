   3.8917814857184277`*^9, 
   3.891781531644732*^9}},ExpressionUUID->"41520569-4b47-4f0e-a1f0-\
c87e0aab6ff5"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
***** E3 ***** 
k=0  -- > 2-sig(E3)=(4,5,4)
     if u=1(mod 4) --->  Cond 3 ---> II
     if u=3(mod 4) --->  No Cond 3 + No Cond 4 -- > IV
k>0  -- > 2-sig(E3)= (5 + 2 k, 5, 4) 
     if u=1(mod 4) --->  Cond 3 ---> II
     if u=3(mod 4) --->  No Cond 3  -- > IV\
\>", "Subsection",
 CellChangeTimes->{{3.886252818573275*^9, 3.886252859005006*^9}, {
