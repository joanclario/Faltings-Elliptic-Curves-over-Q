Cell["\<\
Therefore
if u=1(mod 4) --->  Psi2 (r) != t^2 (mod 4)  -- -> Cond 3 ---> II
if u=3(mod 4) --->  Psi2 (r) = t^2 (mod 4)  -- -> NO Cond 3 ---> IV
\
\>", "Text",
 CellChangeTimes->{{3.8908005954152946`*^9, 3.890800631546235*^9}, {
   3.890801263158353*^9, 3.890801283959795*^9}, {3.890824021008238*^9, 
   3.89082402922071*^9}, {3.890824144086166*^9, 3.8908241539730053`*^9}, {
