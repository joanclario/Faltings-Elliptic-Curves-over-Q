Cell["\<\
iso=2^n--->  
2 - sig (E1) = {4, 3 + 2 n, 6}-- > Condition 3?
2 - sig (E1) = {5, 5 + 2 n, 9} ----> III
2 - sig (E1) = {6,7+2 n,12} --->Condition 7\[CloseCurlyQuote]?
2 - sig (E1) = {7,9+2 n,15} ----> III^*


\
\>", "Text",
 CellChangeTimes->{{3.8928746663553343`*^9, 3.892874762130652*^9}, {
  3.8928765397629433`*^9, 
  3.8928765909346333`*^9}},ExpressionUUID->"1cfb9e75-0efe-40b2-bf8e-\
03a03a79985e"]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
E2 ---  
\tm=4n       --- iso=2^n--->  -->  2 - sig (E2) = {6,6+2 n,12}-- > Condition \
7\[CloseCurlyQuote]?
\tm=4n+1  --- iso=2^n--->  -->  2 - sig (E2) = {7,8+2 n,15} ----> III^*
\tm=4n+2  --- iso=2^(n+1)--->   2 - sig (E2) = {4,4+2 n,6}---> Condition 3?
\tm=4n+3  --- iso=2^(n+1)--->  2 - sig (E2) = {5,6+2 n,9}---> III \
\>", "Subsection",
