   3.990668018277915*^9}, 
   3.991049666438471*^9},ExpressionUUID->"16efad60-0db5-416d-9a1d-\
ce22ec5f5585"],

Cell["\<\
aInvariants[c4,c6]
Given the c-invariants c4 and c6 of an elliptic curve E,   
this function returns the corresponding coefficients {a4, a6}  of the short \
Weierstrass equation 
  y^2 = x^3 + a4 x + a6
using the relations
   a4 = -c4/48,
   a6 = -c6/864.\
\>", "Text",
 CellChangeTimes->{
  3.990668515099354*^9, {3.990668711294724*^9, 3.990668748113006*^9}, {
   3.991049684125448*^9, 3.991049688373836*^9}, {3.99104991174494*^9, 
   3.9910500573305283`*^9}, {3.991050235804418*^9, 
   3.991050278812703*^9}},ExpressionUUID->"b58c2679-cf6f-4271-bfd3-\
69f610476dba"],

Cell[BoxData[
 RowBox[{
  RowBox[{"aInvariants", "[", 
   RowBox[{"c4_", ",", "c6_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "c4"}], "/", "48"}], ",", 
    RowBox[{
     RowBox[{"-", "c6"}], "/", "864"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.991049681538488*^9, 3.991049758442471*^9}, {
  3.9910500946855*^9, 3.9910500974481287`*^9}, {3.991050241722801*^9, 
  3.991050245677408*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"ff73af90-8a6b-46e7-9603-667c661b88c3"]
}, Closed]]
}, Closed]],

