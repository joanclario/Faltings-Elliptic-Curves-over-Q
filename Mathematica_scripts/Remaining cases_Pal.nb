Cell[CellGroupData[{

Cell["Vision", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, 
   3.990667957557056*^9, {3.99067246543884*^9, 
   3.990672466608118*^9}},ExpressionUUID->"136d1d52-7dc7-458f-bcde-\
50b9dbb26dde"],

Cell["\<\
Vision[P, u]
Factors the polynomial or expression P.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
 This is a diagnostic helper function for inspecting the coefficients of the \
factors of P.
  The function uses FactorList, which is safer than applying List directly to \
Factor[P], because it avoids splitting irreducible sums into terms.\
\>", "Text",
 CellChangeTimes->{
  3.990668503318449*^9, {3.9906686471060133`*^9, 3.9906686674900217`*^9}, {
   3.990672476810256*^9, 
   3.990672477733142*^9}},ExpressionUUID->"4d55aa90-ebb1-489d-9bef-\
e6d3208ff9f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Vision", "[", 
   RowBox[{"P_", ",", "u_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"L", "=", 
     RowBox[{"Factor", "[", "P", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "<=", 
       RowBox[{"Length", "@", "L"}]}], ",", 
      RowBox[{"i", "++"}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"i", ",", "\"\< <---> \>\"", ",", 
         RowBox[{"L", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", " ", 
       RowBox[{"Print", "@", 
        RowBox[{"MatrixForm", "@", 
         RowBox[{"Transpose", "@", 
          RowBox[{"{", 
           RowBox[{"CoefficientList", "[", 
            RowBox[{
             RowBox[{"L", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", "u"}], "]"}], 
           "}"}]}]}]}]}]}], "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886401267026865*^9, 3.8864012679454947`*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"d609b531-9c70-43f4-8d4a-4cabc618b9af"]
}, Open  ]],

Cell[CellGroupData[{

Cell["VisionMod", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990672485630422*^9, 
   3.990672486506579*^9}},ExpressionUUID->"1b59f563-b2fe-4c6c-9e25-\
9c4e99b27173"],

Cell["\<\
AyudaMod[P, u, p]
First reduces P modulo p and factors the result.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
This is useful for studying the factorization and coefficients of P modulo p.\
\
\>", "Text",
 CellChangeTimes->{
  3.990668506896264*^9, {3.990668672078745*^9, 
   3.990668680314468*^9}},ExpressionUUID->"072cf932-4f63-491c-b142-\
0984bbe08af0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"VisionMod", "[", 
   RowBox[{"P_", ",", " ", "u_", ",", " ", "p_"}], "]"}], " ", ":=", "\n", 
  "  ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"L", ",", " ", "Q", ",", " ", "i"}], "}"}], ",", "\n", "    ", 
    RowBox[{
     RowBox[{"Q", " ", "=", " ", 
      RowBox[{"PolynomialMod", "[", 
       RowBox[{"P", ",", " ", "p"}], "]"}]}], ";", "\n", "    ", 
     RowBox[{"L", " ", "=", " ", 
      RowBox[{
       RowBox[{"FactorList", "[", "Q", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"2", " ", ";;"}], ",", " ", "1"}], "]"}], "]"}]}], ";", "\n",
      "    ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"L", " ", "===", " ", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"L", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{"Factor", "[", "Q", "]"}], "}"}]}]}], "  ", "]"}], ";", "\n",
      "    ", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", " ", "=", " ", "1"}], ",", " ", 
       RowBox[{"i", " ", "<=", " ", 
        RowBox[{"Length", "[", "L", "]"}]}], ",", " ", 
       RowBox[{"i", "++"}], ",", "  ", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"i", ",", " ", "\"\< <---> \>\"", ",", " ", 
          RowBox[{"L", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", " ", "@", " ", 
         RowBox[{"MatrixForm", " ", "@", " ", 
          RowBox[{"Transpose", " ", "@", " ", 
           RowBox[{"{", 
            RowBox[{"CoefficientList", "[", 
             RowBox[{
              RowBox[{"L", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", " ", "u"}], "]"}], 
            "}"}]}]}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], 
   "\[IndentingNewLine]", " ", "]"}]}]], "Input",
 CellChangeTimes->{{3.9906724917628393`*^9, 
  3.990672529367728*^9}},ExpressionUUID->"630c5346-d490-4726-9fbd-\
dbe91981a03e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["powerPrime", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
