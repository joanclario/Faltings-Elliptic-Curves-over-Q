        "\[IndentingNewLine]", 
        RowBox[{"Print", " ", "@", " ", 
         RowBox[{"MatrixForm", " ", "@", " ", 
          RowBox[{"Transpose", " ", "@", " ", 
           RowBox[{"{", 
            RowBox[{"CoefficientList", "[", 
             RowBox[{
              RowBox[{"L", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", " ", "u"}], "]"}], 
            "}"}]}]}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], 
