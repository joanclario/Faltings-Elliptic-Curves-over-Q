Cell[TextData[{
 "p - sig (E1) = (m, m, 2m)\n   ------->   m=6n+k ---> k=0,1,2,3,4,5\
\[LineSeparator]    p - sig (E1)=(6n+k, 6n+k, 12n+2k)  \n   -------> u=p^n \n \
  ----------------->  p - sig (E1)=(2n+k,k,2k)  \n   k=0 ------> p - sig \
(E1)=(2n ,0, 0)=(\[GreaterEqual]0,0,0) ----> ",
 Cell[BoxData[
  SubscriptBox["I", "0"]],
  CellChangeTimes->{3.886252756526535*^9},ExpressionUUID->
  "05a34dc5-c170-435a-841c-716a2a6f9f7b"],
 "\n   k=1 ------> p - sig (E1)=(2n+1, 1, 2)=(\[GreaterEqual]1, 1, 2)  ----> ",
 Cell[BoxData["II"],
  CellChangeTimes->{3.886252756526535*^9},ExpressionUUID->
  "114159eb-f5c2-4f04-a833-45d643171a46"],
 "\n   k=2 ------> p - sig (E1)=(2n+2, 2, 4)=(\[GreaterEqual]2, 2, 4) ----> \
",
 Cell[BoxData["IV"],
  CellChangeTimes->{3.886252756526535*^9},ExpressionUUID->
  "07bf53a9-ac87-4d75-847a-f5d47b19c1d3"],
 "\n   k=3 ------> p - sig (E1)=(2n+3, 3, 6)=(\[GreaterEqual]3, 3, 6)----> ",
 Cell[BoxData[
  SubsuperscriptBox["I", "0", "*"]],
  CellChangeTimes->{3.886252756526535*^9},ExpressionUUID->
  "b4d5bc86-fe3e-4557-b848-2a8f25e6906d"],
 "   \n   k=4 ------> p - sig (E1)=(2n+4, 4, 8)=(\[GreaterEqual]4, 4, 8) \
----> ",
 Cell[BoxData[
  SuperscriptBox["IV", "*"]],
  CellChangeTimes->{3.886252756526535*^9},ExpressionUUID->
  "e37d3cd0-fbd4-4b76-8bdf-17ab40140bd6"],
 " \n   k=5 ------> p - sig (E1)=(2n+5, 5, 10)=(\[GreaterEqual]5, 5, 10)---->",
 Cell[BoxData[
  SuperscriptBox["II", "*"]],
  CellChangeTimes->{3.886252756526535*^9},ExpressionUUID->
  "11edf4ae-f187-4db9-806d-c265f0b868ef"],
 "  \n   "
}], "Text",
