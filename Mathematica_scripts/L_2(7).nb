          RowBox[{"{", 
           RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
          RowBox[{"t", "\[Rule]", 
           RowBox[{
            RowBox[{"p", "^", 
             RowBox[{"-", "m"}]}], "*", "u"}]}]}], ",", 
