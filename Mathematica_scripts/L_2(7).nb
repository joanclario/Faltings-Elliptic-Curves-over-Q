Cell["\<\
if u=1 (mod 4): (2n+k+1,k+1,2+2k)
    k = 0 -- -> (2 n+1, 1, 2) -- n no 0 -> (>= 1, 1, 2)-- > II
   k = 1 -- -> (2 n + 2, 2, 4)-- n no 0 -> (>= 4, 2, 4)-- > IV
    k = 2-- -> (2 n + 3, 3, 6) -> (>= 3, 3, 6)-- > I_ 0^*
    k = 3 -- -> (2 n + 4, 4, 8)-- > (>= 4, 4, 8)-- > IV^*
    k = 4 -- -> (2 n + 5, 5, 10)-- > (>= 5, 5, 10)-- > II^*
    k = 5 -- -> (2 n + 6, 6, 12) = u = 7 > (2 n + 2, 0, 0) = (>= 2, 0, 0) -- \
> I_ 0\
\>", "Text",
