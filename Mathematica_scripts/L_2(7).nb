Cell["\<\
Let be m = 6 n + k (k = 0, 1, 2, 3, 4, 5):\[LineSeparator]p - sig (E1) = (6 n \
+ k, 6 n + k, 12 n+2k)
    Iso = 7^n 
        p - sig (E1) = (2 n + k , k, 2k)
    k = 0 -- -> (2 n, 0, 0) -- n no 0 -> (>= 2, 0, 0)-- > I_0
   k = 1 -- -> (2 n + 1, 1, 2)--> (>= 1, 1, 2)-- > II
    k = 2-- -> (2 n + 2, 2, 4) -> (>= 2, 2, 4)-- > IV
    k = 3 -- -> (2 n + 3, 3, 6)-- > (>= 3, 3, 6)-- > I0^*
    k = 4 -- -> (2 n + 4, 4, 8)-- > (>= 4, 4, 8)-- > IV^*
    k = 5 -- -> (2 n + 5, 5, 10) --> (>= 5, 5, 10) -- > II^*
         \
\>", "Text",
 CellChangeTimes->{{3.888122360897525*^9, 3.8881223804239073`*^9}, {
  3.888129597007554*^9, 
  3.888129598067211*^9}},ExpressionUUID->"a01f05c7-e8f6-4d5c-81c3-\
cf39bd83ce19"]
}, Open  ]],

