7d66a25323ba"],

Cell["\<\
SpecificPowerPrint[c4, c6, Delta, p, m]
Replaces t by p^m*u for a specified exponent m.
It prints the associated Weierstrass coefficients
    a4 = -c4/48,
    a6 = -c6/864,
and returns the transformed and factored triple {c4, c6, Delta}.\
\>", "Text",
 CellChangeTimes->{
  3.990668485703532*^9, {3.990668559439372*^9, 
   3.9906685680455847`*^9}},ExpressionUUID->"202ed987-cdb3-4d88-bae6-\
10e08f830df7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SpecificPowerPrint", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"Factor", "@", 
      RowBox[{"Refine", "@", 
       RowBox[{"PowerExpand", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
         RowBox[{"t", "\[Rule]", 
          RowBox[{
           RowBox[{"p", "^", "m"}], "*", "u"}]}]}], "]"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<c4=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "/", "48"}]}], ",", 
       RowBox[{"\"\<c6=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "/", "864"}]}]}], "}"}], "]"}], ";",
     "\[IndentingNewLine]", " ", 
    RowBox[{"Return", "[", "M", "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886304183922884*^9, 3.886304218856881*^9}, {
  3.8864242640941772`*^9, 3.886424274426693*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"c9a116c3-000b-402a-ab8b-2aece4166515"]
}, Closed]],

Cell[CellGroupData[{

Cell["Twist", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.9906679078802147`*^9}},ExpressionUUID->"a38f0d96-e3ca-4b5e-8d5e-\
7af2b7b7659a"],

Cell["\<\
Twist[{c4, c6, Delta}, s]
 Applies the standard scaling transformation to the invariants of an elliptic \
curve.
 Under a change of variables with scaling factor s, the invariants transform as
    c4    -> c4/s^4,
    c6    -> c6/s^6,
    Delta -> Delta/s^12.
 The resulting expressions are power - expanded, refined, and factored.\
\>", "Text",
 CellChangeTimes->{
  3.9906684897516203`*^9, {3.9906685763156033`*^9, 
   3.99066859000504*^9}},ExpressionUUID->"c540cdcd-7d77-4e0f-a1c6-\
18f9fbab3e77"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Twist", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"c4_", ",", "c6_", ",", "Delta_"}], "}"}], ",", "s_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"PowerExpand", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"c4", "/", 
        RowBox[{"s", "^", "4"}]}], ",", 
       RowBox[{"c6", "/", 
        RowBox[{"s", "^", "6"}]}], ",", 
       RowBox[{"Delta", "/", 
        RowBox[{"s", "^", "12"}]}]}], "}"}], "]"}], "//", "Refine"}], "//", 
   "Factor"}]}]], "Input",
 CellChangeTimes->{{3.8862536998964443`*^9, 3.886253769114563*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"4e043ce1-70ca-408b-a2bd-7e2e50fdf0a0"]
}, Closed]],

Cell[CellGroupData[{

Cell["CuentaP2 ", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.9906679276567574`*^9}},ExpressionUUID->"7e9b6cf2-bacc-40e4-acec-\
5b57e4371919"],

Cell["\<\
CuentaP2[c4, c6, m]
Computes the congruence expression
   (c6/3^3)^2 + 2 - 3 c4/3^2
after the substitution t = 3^m u.
The expression is power - expanded, refined, factored, and then reduced \
modulo 9.
This function is intended to check a local congruence condition at p = 3.\
\[LineSeparator]Condition P2 in Papadopoulus\[CloseCurlyQuote]s paper for p=3 \
(Section II.2, Tableaus II)\
\>", "Text",
 CellChangeTimes->{{3.990668254622575*^9, 3.990668255780031*^9}, 
   3.990668492990816*^9, {3.990668598544017*^9, 3.990668605585143*^9}, {
   3.990672598122566*^9, 3.990672625986929*^9}, {3.990672681549316*^9, 
   3.990672696935503*^9}, {3.990672770157649*^9, 
   3.990672775668046*^9}},ExpressionUUID->"f3e71f5c-1801-466d-af6c-\
d7a2255ba364"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CuentaP2", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c6", "/", 
            RowBox[{"3", "^", "3"}]}], ")"}], "^", "2"}], "+", "2", "-", 
         RowBox[{"3", " ", 
          RowBox[{"c4", "/", 
           RowBox[{"3", "^", "2"}]}]}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"3", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "9"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.990672383534123*^9},
 CellLabel->"In[8]:=",ExpressionUUID->"ceff11e3-a839-45af-8a6c-2953fc09d5ae"]
}, Closed]],

Cell[CellGroupData[{

Cell["CuentaP5", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.990667934470553*^9}},ExpressionUUID->"832993eb-ac7d-433c-b9ec-\
fa5d976b6051"],

Cell["\<\
CuentaP5[c4, c6, m]
Computes the congruence expression
      (c6/3^6)^2 + 2 - 3 c4/3^4
after the substitution t = 3^m u.
The expression is power - expanded, refined, factored, and then reduced \
modulo 9.
This function is intended to check a related local congruence condition at p \
= 3.
Condition P5 in Papadopoulus\[CloseCurlyQuote]paper for p=3 (Section II.2, \
Tableaus II)\
\>", "Text",
 CellChangeTimes->{
  3.990668495850008*^9, {3.990668608689356*^9, 3.990668629771914*^9}, {
   3.990672631848387*^9, 3.990672635188414*^9}, 3.990672703406727*^9, {
   3.9906727651735888`*^9, 
   3.990672766140173*^9}},ExpressionUUID->"5fd9e78e-8af8-488b-b198-\
5b49e5d58424"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CuentaP5", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c6", "/", 
            RowBox[{"3", "^", "6"}]}], ")"}], "^", "2"}], "+", "2", "-", 
         RowBox[{"3", " ", 
          RowBox[{"c4", "/", 
           RowBox[{"3", "^", "4"}]}]}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"3", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "9"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.99067240018237*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"8aceee2f-d1ed-4f0b-86df-5f2ccadf1fc5"]
}, Closed]],

Cell[CellGroupData[{

Cell["PolandLemma22", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, 
   3.990667946386627*^9},ExpressionUUID->"a9d1eabf-1055-46d8-a25b-\
14f1da0ce40c"],

Cell["\<\
PolandLemma22[c6, m, n]
Computes c6/2^n after the substitution t = 2^m u.
The expression is power - expanded, refined, factored, and reduced modulo 4.
This appears to be designed to verify a congruence condition related to Lemma \
2.2 in Browkin & Davies\[CloseCurlyQuote] paper.\
\>", "Text",
 CellChangeTimes->{
  3.990668499775419*^9, {3.990668633753881*^9, 3.990668643091579*^9}, {
   3.9906727441943703`*^9, 
   3.99067275898619*^9}},ExpressionUUID->"498e1ff8-6b76-4ef4-b148-\
2e3edd393f32"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PolandLemma22", "[", 
   RowBox[{"c6_", ",", "m_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{"c6", "/", 
         RowBox[{"2", "^", "n"}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"2", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "4"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.886303098200499*^9, 3.886303176740327*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"b5e7c82e-b13d-4428-81ca-d44506452c8e"]
}, Closed]],

Cell[CellGroupData[{

Cell["Vision", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, 
   3.990667957557056*^9, {3.99067246543884*^9, 
   3.990672466608118*^9}},ExpressionUUID->"2ac92778-06ed-4ad0-946e-\
441997a264b6"],

Cell["\<\
Vision[P, u]
Factors the polynomial or expression P.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
 This is a diagnostic helper function for inspecting the coefficients of the \
factors of P.
  The function uses FactorList, which is safer than applying List directly to \
Factor[P], because it avoids splitting irreducible sums into terms.\
\>", "Text",
 CellChangeTimes->{
  3.990668503318449*^9, {3.9906686471060133`*^9, 3.9906686674900217`*^9}, {
   3.990672476810256*^9, 
   3.990672477733142*^9}},ExpressionUUID->"38c77b79-a43f-425f-95e1-\
cac12f1c2a9e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Vision", "[", 
   RowBox[{"P_", ",", "u_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"L", "=", 
     RowBox[{"Factor", "[", "P", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "<=", 
       RowBox[{"Length", "@", "L"}]}], ",", 
      RowBox[{"i", "++"}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"i", ",", "\"\< <---> \>\"", ",", 
         RowBox[{"L", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", " ", 
       RowBox[{"Print", "@", 
        RowBox[{"MatrixForm", "@", 
         RowBox[{"Transpose", "@", 
          RowBox[{"{", 
           RowBox[{"CoefficientList", "[", 
            RowBox[{
             RowBox[{"L", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", "u"}], "]"}], 
           "}"}]}]}]}]}]}], "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886401267026865*^9, 3.8864012679454947`*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"d079745b-fb00-476d-b766-95ed117e722e"]
}, Closed]],

Cell[CellGroupData[{

Cell["VisionMod", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990672485630422*^9, 
   3.990672486506579*^9}},ExpressionUUID->"7a2156fd-a9ab-4b1b-bc54-\
9f30820c7380"],

Cell["\<\
AyudaMod[P, u, p]
First reduces P modulo p and factors the result.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
This is useful for studying the factorization and coefficients of P modulo p.\
\
\>", "Text",
 CellChangeTimes->{
  3.990668506896264*^9, {3.990668672078745*^9, 
   3.990668680314468*^9}},ExpressionUUID->"d6cda333-e5b8-4cd3-9634-\
237995ccef67"],

Cell[BoxData[
 RowBox[{
  RowBox[{"VisionMod", "[", 
   RowBox[{"P_", ",", " ", "u_", ",", " ", "p_"}], "]"}], " ", ":=", "\n", 
  "  ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"L", ",", " ", "Q", ",", " ", "i"}], "}"}], ",", "\n", "    ", 
    RowBox[{
     RowBox[{"Q", " ", "=", " ", 
      RowBox[{"PolynomialMod", "[", 
       RowBox[{"P", ",", " ", "p"}], "]"}]}], ";", "\n", "    ", 
     RowBox[{"L", " ", "=", " ", 
      RowBox[{
       RowBox[{"FactorList", "[", "Q", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"2", " ", ";;"}], ",", " ", "1"}], "]"}], "]"}]}], ";", "\n",
      "    ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"L", " ", "===", " ", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"L", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{"Factor", "[", "Q", "]"}], "}"}]}]}], "  ", "]"}], ";", "\n",
      "    ", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", " ", "=", " ", "1"}], ",", " ", 
       RowBox[{"i", " ", "<=", " ", 
        RowBox[{"Length", "[", "L", "]"}]}], ",", " ", 
       RowBox[{"i", "++"}], ",", "  ", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"i", ",", " ", "\"\< <---> \>\"", ",", " ", 
          RowBox[{"L", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", " ", "@", " ", 
         RowBox[{"MatrixForm", " ", "@", " ", 
          RowBox[{"Transpose", " ", "@", " ", 
           RowBox[{"{", 
            RowBox[{"CoefficientList", "[", 
             RowBox[{
              RowBox[{"L", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", " ", "u"}], "]"}], 
            "}"}]}]}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], 
   "\[IndentingNewLine]", " ", "]"}]}]], "Input",
 CellChangeTimes->{{3.9906724917628393`*^9, 3.990672529367728*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"b612463e-5797-4af6-a3c1-0dc5572f6e89"]
}, Closed]],

Cell[CellGroupData[{

Cell["powerPrime", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, 
   3.990668002047792*^9},ExpressionUUID->"d4e3b0c9-b45f-4c19-b7d8-\
b283463bf5d1"],

Cell["\<\
powerPrime[n, p]
Computes the exponent of the prime p in the prime factorization of n.
 In other words, it returns the p - adic valuation v_p (n).\
\>", "Text",
 CellChangeTimes->{
  3.990668512216362*^9, {3.990668685634695*^9, 
   3.990668705264998*^9}},ExpressionUUID->"7ef291bc-1aca-4edf-a462-\
94a4af96486c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"powerPrime", "[", 
   RowBox[{"n_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "f", "}"}], ",", 
    RowBox[{
     RowBox[{"f", "=", 
      RowBox[{"FactorInteger", "[", "n", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"k", "=", 
      RowBox[{"Cases", "[", 
       RowBox[{"f", ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"p", ",", "k_"}], "}"}], "\[RuleDelayed]", "k"}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"k", "\[Equal]", 
        RowBox[{"{", "}"}]}], ",", "0", ",", 
       RowBox[{"k", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8872517996742373`*^9, 3.887251812890751*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"ae61895b-3bc5-45b8-a6d8-4a52aacc2d4d"]
}, Closed]],

Cell[CellGroupData[{

Cell["pIntegralModel", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990668014657935*^9, 
   3.990668018277915*^9}},ExpressionUUID->"3f578870-f44f-45d0-a72b-\
fa6d1151342e"],

Cell["\<\
pIntegralModel[M, p]
Checks whether the Weierstrass coefficients associated to the invariant \
triple M are p - integral.
The input M is expected to be a list of the form
      M = {c4, c6, Delta}.
The corresponding Weierstrass coefficients are computed as
    a4 = -M[[1]]/48,
    a6 = -M[[2]]/864.
 The function then checks whether the denominators of a4 and a6 are divisible \
by p.
 It returns True if both coefficients are p - integral.
 If at least one coefficient is not p - integral, it prints {a4, a6} and \
returns False.\
\>", "Text",
 CellChangeTimes->{
  3.990668515099354*^9, {3.990668711294724*^9, 
   3.990668748113006*^9}},ExpressionUUID->"88fec764-2e3c-4135-8506-\
71bdcebedbf5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pIntegralModel", "[", 
   RowBox[{"M_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"F", ",", "L"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"F", "=", 
      RowBox[{"Factor", "@", 
       RowBox[{"Refine", "@", 
        RowBox[{"PowerExpand", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{"M", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], "/", "48"}], ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"M", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "/", "864"}]}], "}"}], 
         "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"L", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"powerPrime", "[", 
         RowBox[{
          RowBox[{"Denominator", "@", 
           RowBox[{"F", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", "p"}], "]"}], ",", 
        RowBox[{"powerPrime", "[", 
         RowBox[{
          RowBox[{"Denominator", "@", 
           RowBox[{"F", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", "p"}], "]"}]}], "}"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"L", "\[Equal]", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], ",", "True", ",", " ", 
       RowBox[{
        RowBox[{"Print", "[", "L", "]"}], ";", "False"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.8872080410140142`*^9, 3.8872081043152437`*^9}, {
  3.887208226545286*^9, 3.887208239810857*^9}, {3.887208283031227*^9, 
  3.887208385892682*^9}, {3.8872514232683887`*^9, 3.887251491833002*^9}, {
  3.887251557834517*^9, 3.8872515674537363`*^9}, {3.887251831685504*^9, 
  3.8872518580315332`*^9}, {3.887251912020729*^9, 3.8872520142963457`*^9}, {
  3.887252068933837*^9, 3.887252093188457*^9}, {3.887252292695537*^9, 
  3.887252335330195*^9}, {3.9906725807675543`*^9, 3.9906725819134483`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"0a826008-e45f-4756-836d-5008d1163f6a"]
}, Closed]],

Cell[CellGroupData[{

Cell["aInvariants", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990668014657935*^9, 
   3.990668018277915*^9}, 
   3.991049666438471*^9},ExpressionUUID->"da5ac57f-6292-4e7e-bdbe-\
566353e85b48"],

Cell["\<\
aInvariants[c4,c6]
Given the c-invariants c4 and c6 of an elliptic curve E,   
this function returns the corresponding coefficients {a4, a6}  of the short \
Weierstrass equation 
  y^2 = x^3 + a4 x + a6
using the relations
   a4 = -c4/48,
   a6 = -c6/864.\
