Cell["Let be m = 6 n + k (k = 0, 1, 2, 3, 4, 5)", "Text",
 CellChangeTimes->{{3.888122360897525*^9, 
  3.8881223804239073`*^9}},ExpressionUUID->"0715a33d-2bec-4d80-8783-\
475b58aacef8"],

Cell["\<\
* if u = 1 (mod 7) === >    p - sig (E1) = (6 n + k + 1, 6 n + k, 12 n+2k)
    Iso = 7^n 
        p - sig (E1) = (2 n + k + 1, k, 2k)
    k = 0 -- -> (2 n+1, 0, 0) -- n no 0 -> (>= 3, 0, 0)-- > I_0
   k = 1 -- -> (2 n + 2, 1, 2)--> (>= 2, 1, 2)-- > II
    k = 2-- -> (2 n + 3, 2, 4) -> (>= 3, 2, 4)-- > IV
    k = 3 -- -> (2 n + 4, 3, 6)-- > (>= 4, 3, 6)-- > I0^*
    k = 4 -- -> (2 n + 5, 4, 8)-- > (>= 5, 4, 8)-- > IV^*
    k = 5 -- -> (2 n + 6, 5, 10) --> (>= 6, 5, 10) -- > II^*
         \
\>", "Text",
 CellChangeTimes->{
  3.88812229751381*^9, {3.888122385285861*^9, 3.8881226418789797`*^9}, {
   3.8881227190234137`*^9, 
   3.888122753555484*^9}},ExpressionUUID->"33dab4ce-16b6-40ab-bac3-\
893d52d19a44"],

Cell["\<\
* Otherwise === >    p - sig (E1) = (6 n + k, 6 n + k, 12 n+2k)
    Iso = 7^n 
        p - sig (E1) = (2 n + k , k, 2k)
    k = 0 -- -> (2 n, 0, 0) -- n no 0 -> (>= 2, 0, 0)-- > I_0
   k = 1 -- -> (2 n + 1, 1, 2)--> (>= 1, 1, 2)-- > II
    k = 2-- -> (2 n + 2, 2, 4) -> (>= 2, 2, 4)-- > IV
    k = 3 -- -> (2 n + 3, 3, 6)-- > (>= 3, 3, 6)-- > I0^*
    k = 4 -- -> (2 n + 4, 4, 8)-- > (>= 4, 4, 8)-- > IV^*
    k = 5 -- -> (2 n + 5, 5, 10) --> (>= 5, 5, 10) -- > II^*
         \
\>", "Text",
 CellChangeTimes->{
  3.88812229751381*^9, {3.888122385285861*^9, 3.8881226418789797`*^9}, {
   3.8881227190234137`*^9, 3.888122791450808*^9}, {3.8881228228772717`*^9, 
   3.888122827326542*^9}},ExpressionUUID->"bb979dbc-7f5c-4252-999c-\
f47fd0aad030"]
}, Open  ]],

