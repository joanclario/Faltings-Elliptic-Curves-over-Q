Cell["\<\

m = 4 k  -- -----u=5^k+1--------> (1, 1+ 2 k+n, 3)-- -> III
m = 4 k + 1 -- -----u=5^k+1--------> (2, 3 + 2 k+n, 6)-- -> I0^*
 m = 4 k + 2 -- -----u=5^k+1--------> (3, 5 + 2 k+n, 9)-- -> III^*
 m = 4 k  +3   -- ---------> (4, 7 + 2 k+n, 12)   -- u=5^(k+2)-----> (0, 1+2 \
