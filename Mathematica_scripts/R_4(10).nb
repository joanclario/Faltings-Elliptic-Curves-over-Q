Cell[CellGroupData[{

Cell["PositivePower", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9},ExpressionUUID->"d2d7441e-7c27-44ef-a57d-\
9bb9062bccf8"],

Cell["\<\
Replaces t by p^m*u in the invariants {c4, c6, Delta}, assuming m > 0.
 The resulting expressions are power - expanded, refined under the assumption \
m > 0, and factored.
 This is useful for studying the behaviour of the invariants under the
 substitution t = p^m u, for positive powers of p.\
\>", "Text",
 CellChangeTimes->{{3.99066742936615*^9, 3.990667461814023*^9}, {
  3.990667541132284*^9, 
  3.990667541704321*^9}},ExpressionUUID->"1b97ddac-401f-45b0-92dd-\
52b32036dbbc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PositivePower", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"PowerExpand", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
       RowBox[{"t", "\[Rule]", 
        RowBox[{
         RowBox[{"p", "^", "m"}], "*", "u"}]}]}], ",", 
      RowBox[{"Assumptions", "\[Rule]", 
       RowBox[{"m", ">", "0"}]}]}], "]"}], "//", "Refine"}], "//", 
   "Factor"}]}]], "Input",
 CellChangeTimes->{{3.886252437665538*^9, 3.886252438649626*^9}, 
   3.886252966474904*^9, {3.8862534977113247`*^9, 3.886253572623859*^9}, 
   3.886253663508657*^9, {3.886303774189517*^9, 3.886303798869195*^9}, {
   3.886303887860013*^9, 3.8863039781520557`*^9}, {3.886304023287404*^9, 
   3.886304065680294*^9}, {3.886304123162631*^9, 3.886304146399413*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"23a5e09e-976c-4bbb-b545-1b6db39d4f1a"]
}, Closed]],

Cell[CellGroupData[{

Cell["NegativePower ", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667834522991*^9, 
   3.990667845042171*^9}},ExpressionUUID->"ce87cc6d-3184-491c-a751-\
c796f83ee6a5"],

Cell["\<\
NegativePower[c4, c6, Delta, p]
 Replaces t by p^(-m)*u in the invariants {c4, c6, Delta}, assuming m > 0.
 The resulting expressions are power - expanded, refined under the assumption \
m > 0, and factored.
 This is useful for studying the behaviour of the invariants under the  \
substitution t = p^(-m) u.\
\>", "Text",
 CellChangeTimes->{
  3.99066806174842*^9, {3.990668098232123*^9, 
   3.990668115556229*^9}},ExpressionUUID->"ce9a2c6c-eaa9-4f3b-b648-\
882ec15b355b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"NegativePower", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"PowerExpand", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
       RowBox[{"t", "\[Rule]", 
        RowBox[{
         RowBox[{"p", "^", 
          RowBox[{"-", "m"}]}], "*", "u"}]}]}], ",", 
      RowBox[{"Assumptions", "\[Rule]", 
       RowBox[{"m", ">", "0"}]}]}], "]"}], "//", "Refine"}], "//", 
   "Factor"}]}]], "Input",
 CellChangeTimes->{{3.883822720420061*^9, 3.883822742251875*^9}, {
  3.886252357843708*^9, 3.886252374960618*^9}, {3.886252939674118*^9, 
  3.886252963201332*^9}, {3.886253103804723*^9, 3.8862531044520082`*^9}, {
  3.886253527915574*^9, 3.886253565858328*^9}, {3.886253631838805*^9, 
  3.886253633108219*^9}, {3.886253668128891*^9, 3.88625367066061*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"18a4e492-9002-4380-8dc0-6afcdd8619ee"]
}, Closed]],

Cell[CellGroupData[{

Cell["SpecificPower", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, 
   3.990667847976283*^9},ExpressionUUID->"8488a79f-b2c3-46a1-8961-\
0685d8ed52dd"],

Cell["\<\
SpecificPower[c4, c6, Delta, p, m]
Replaces t by p^m*u for a specified exponent m.
The resulting triple {c4, c6, Delta} is power - expanded, refined, and \
factored.
Unlike PositivePower and NegativePower, here m is given as an explicit \
argument of the function.\
\>", "Text",
 CellChangeTimes->{
  3.990668091041304*^9, {3.990668124242468*^9, 
   3.9906681365823298`*^9}},ExpressionUUID->"ce691ddd-4a22-473a-8602-\
3efd1a084a4b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SpecificPower", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_", ",", "m_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"PowerExpand", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
      RowBox[{"t", "\[Rule]", 
       RowBox[{
        RowBox[{"p", "^", "m"}], "*", "u"}]}]}], "]"}], "//", "Refine"}], "//",
    "Factor"}]}]], "Input",
 CellChangeTimes->{{3.886253599799819*^9, 3.886253616995083*^9}, 
   3.886256283304056*^9},
 CellLabel->"In[3]:=",ExpressionUUID->"ad57badf-d3bf-4597-a054-0d867ea04370"]
}, Closed]],

Cell[CellGroupData[{

Cell["PositivePowerPrint", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, 
   3.990667865470902*^9},ExpressionUUID->"dcf4d55e-fefc-4287-ab04-\
168e7b7c958e"],

Cell["\<\
PositivePowerPrint[c4, c6, Delta, p]
 Performs the same substitution as PositivePower, namely t = p^m u with m > \
0.
 In addition, it prints the corresponding Weierstrass coefficients
    a4 = -c4/48,
    a6 = -c6/864.
 It returns the transformed and factored triple {c4, c6, Delta}.\
\>", "Text",
 CellChangeTimes->{{3.990668424631196*^9, 
  3.990668441503735*^9}},ExpressionUUID->"3ea39e31-9842-4778-8039-\
2fa8062e363a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PositivePowerPrint", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"Factor", "@", 
      RowBox[{"Refine", "@", 
       RowBox[{"PowerExpand", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
          RowBox[{"t", "\[Rule]", 
           RowBox[{
            RowBox[{"p", "^", "m"}], "*", "u"}]}]}], ",", 
         RowBox[{"Assumptions", "\[Rule]", 
          RowBox[{"m", ">", "0"}]}]}], "]"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<c4=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "/", "48"}]}], ",", 
       RowBox[{"\"\<c6=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "/", "864"}]}]}], "}"}], "]"}], ";",
     "\[IndentingNewLine]", " ", 
    RowBox[{"Return", "[", "M", "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886304132968459*^9, 3.886304133672339*^9}, {
  3.8864242890954514`*^9, 3.886424295644353*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"ee169a43-469b-4beb-ad50-addbfa472aec"]
}, Closed]],

Cell[CellGroupData[{

Cell["NegativePowerPrint ", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667873918776*^9, 
   3.990667886427381*^9}},ExpressionUUID->"2b812b21-40c1-4802-9491-\
2a9ea852f755"],

Cell["\<\
NegativePowerPrint[c4, c6, Delta, p]
Performs the same substitution as NegativePower, namely t = p^(-m) u with m > \
0.
It also prints the corresponding Weierstrass coefficients  
    a4 = -c4/48,
    a6 = -c6/864.
 It returns the transformed and factored triple {c4, c6, Delta}.\
\>", "Text",
 CellChangeTimes->{
  3.990668479549239*^9, {3.990668528820611*^9, 
   3.990668553377615*^9}},ExpressionUUID->"156f5685-ac12-40a4-a284-\
c580105e4b64"],

Cell[BoxData[
 RowBox[{
  RowBox[{"NegativePowerPrint", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"Factor", "@", 
      RowBox[{"Refine", "@", 
       RowBox[{"PowerExpand", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
          RowBox[{"t", "\[Rule]", 
           RowBox[{
            RowBox[{"p", "^", 
             RowBox[{"-", "m"}]}], "*", "u"}]}]}], ",", 
         RowBox[{"Assumptions", "\[Rule]", 
          RowBox[{"m", ">", "0"}]}]}], "]"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<c4=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "/", "48"}]}], ",", 
       RowBox[{"\"\<c6=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "/", "864"}]}]}], "}"}], "]"}], ";",
     "\[IndentingNewLine]", " ", 
    RowBox[{"Return", "[", "M", "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886304161576004*^9, 3.886304167426662*^9}, {
  3.886424276958407*^9, 3.886424286936861*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"3f3fc458-cb03-4cab-8c76-358b7117a0b2"]
}, Closed]],

Cell[CellGroupData[{

Cell["SpecificPowerPrint", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, 
   3.990667884593225*^9},ExpressionUUID->"17f3bb25-cbd8-4ee9-bbb2-\
698367b404c0"],

Cell["\<\
SpecificPowerPrint[c4, c6, Delta, p, m]
Replaces t by p^m*u for a specified exponent m.
It prints the associated Weierstrass coefficients
    a4 = -c4/48,
    a6 = -c6/864,
and returns the transformed and factored triple {c4, c6, Delta}.\
\>", "Text",
 CellChangeTimes->{
  3.990668485703532*^9, {3.990668559439372*^9, 
   3.9906685680455847`*^9}},ExpressionUUID->"465a9ac4-e5fb-4a90-9466-\
3d11d1aace9e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SpecificPowerPrint", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"Factor", "@", 
      RowBox[{"Refine", "@", 
       RowBox[{"PowerExpand", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
         RowBox[{"t", "\[Rule]", 
          RowBox[{
           RowBox[{"p", "^", "m"}], "*", "u"}]}]}], "]"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<c4=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "/", "48"}]}], ",", 
       RowBox[{"\"\<c6=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "/", "864"}]}]}], "}"}], "]"}], ";",
     "\[IndentingNewLine]", " ", 
    RowBox[{"Return", "[", "M", "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886304183922884*^9, 3.886304218856881*^9}, {
  3.8864242640941772`*^9, 3.886424274426693*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"623b48b2-3c9a-4bdb-8432-ff72d82f9f36"]
}, Closed]],

Cell[CellGroupData[{

Cell["Twist", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.9906679078802147`*^9}},ExpressionUUID->"81a67432-7aa5-4c3b-acac-\
80b4d4ce0de3"],

Cell["\<\
Twist[{c4, c6, Delta}, s]
 Applies the standard scaling transformation to the invariants of an elliptic \
curve.
 Under a change of variables with scaling factor s, the invariants transform as
    c4    -> c4/s^4,
    c6    -> c6/s^6,
    Delta -> Delta/s^12.
 The resulting expressions are power - expanded, refined, and factored.\
\>", "Text",
 CellChangeTimes->{
  3.9906684897516203`*^9, {3.9906685763156033`*^9, 
   3.99066859000504*^9}},ExpressionUUID->"08a10adf-865c-48a2-8415-\
ed3f4ab1509a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Twist", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"c4_", ",", "c6_", ",", "Delta_"}], "}"}], ",", "s_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"PowerExpand", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"c4", "/", 
        RowBox[{"s", "^", "4"}]}], ",", 
       RowBox[{"c6", "/", 
        RowBox[{"s", "^", "6"}]}], ",", 
       RowBox[{"Delta", "/", 
        RowBox[{"s", "^", "12"}]}]}], "}"}], "]"}], "//", "Refine"}], "//", 
   "Factor"}]}]], "Input",
 CellChangeTimes->{{3.8862536998964443`*^9, 3.886253769114563*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"45ed2058-f8d7-4e1e-8d59-750af2a2144c"]
}, Closed]],

Cell[CellGroupData[{

Cell["CuentaP2 ", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.9906679276567574`*^9}},ExpressionUUID->"51f20e7e-0445-4e81-84bb-\
f418e2ffe165"],

Cell["\<\
CuentaP2[c4, c6, m]
Computes the congruence expression
   (c6/3^3)^2 + 2 - 3 c4/3^2
after the substitution t = 3^m u.
The expression is power - expanded, refined, factored, and then reduced \
modulo 9.
This function is intended to check a local congruence condition at p = 3.\
\[LineSeparator]Condition P2 in Papadopoulus\[CloseCurlyQuote]s paper for p=3 \
(Section II.2, Tableaus II)\
\>", "Text",
 CellChangeTimes->{{3.990668254622575*^9, 3.990668255780031*^9}, 
   3.990668492990816*^9, {3.990668598544017*^9, 3.990668605585143*^9}, {
   3.990672598122566*^9, 3.990672625986929*^9}, {3.990672681549316*^9, 
   3.990672696935503*^9}, {3.990672770157649*^9, 
   3.990672775668046*^9}},ExpressionUUID->"189006c3-47d9-4b20-8870-\
42a93683533f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CuentaP2", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c6", "/", 
            RowBox[{"3", "^", "3"}]}], ")"}], "^", "2"}], "+", "2", "-", 
         RowBox[{"3", " ", 
          RowBox[{"c4", "/", 
           RowBox[{"3", "^", "2"}]}]}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"3", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "9"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.990672383534123*^9},
 CellLabel->"In[8]:=",ExpressionUUID->"34bd37c0-2ba0-4816-b5fe-9158fd54d405"]
}, Closed]],

Cell[CellGroupData[{

Cell["CuentaP5", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.990667934470553*^9}},ExpressionUUID->"b9cc9517-3e82-4fe4-bc64-\
6d7e69d4ff18"],

Cell["\<\
CuentaP5[c4, c6, m]
Computes the congruence expression
      (c6/3^6)^2 + 2 - 3 c4/3^4
after the substitution t = 3^m u.
The expression is power - expanded, refined, factored, and then reduced \
modulo 9.
This function is intended to check a related local congruence condition at p \
= 3.
Condition P5 in Papadopoulus\[CloseCurlyQuote]paper for p=3 (Section II.2, \
Tableaus II)\
\>", "Text",
 CellChangeTimes->{
  3.990668495850008*^9, {3.990668608689356*^9, 3.990668629771914*^9}, {
   3.990672631848387*^9, 3.990672635188414*^9}, 3.990672703406727*^9, {
   3.9906727651735888`*^9, 
   3.990672766140173*^9}},ExpressionUUID->"d384aa10-2960-4884-b94c-\
a7ce097f83f5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CuentaP5", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c6", "/", 
            RowBox[{"3", "^", "6"}]}], ")"}], "^", "2"}], "+", "2", "-", 
         RowBox[{"3", " ", 
          RowBox[{"c4", "/", 
           RowBox[{"3", "^", "4"}]}]}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"3", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "9"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.99067240018237*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"cb98cb94-a01c-4d92-a901-4d4a448b96eb"]
}, Closed]],

Cell[CellGroupData[{

Cell["PolandLemma22", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, 
   3.990667946386627*^9},ExpressionUUID->"382d7c1d-f53b-4a2b-af4a-\
3e3e8a70fe2c"],

Cell["\<\
PolandLemma22[c6, m, n]
Computes c6/2^n after the substitution t = 2^m u.
The expression is power - expanded, refined, factored, and reduced modulo 4.
This appears to be designed to verify a congruence condition related to Lemma \
2.2 in Browkin & Davies\[CloseCurlyQuote] paper.\
\>", "Text",
 CellChangeTimes->{
  3.990668499775419*^9, {3.990668633753881*^9, 3.990668643091579*^9}, {
   3.9906727441943703`*^9, 
   3.99067275898619*^9}},ExpressionUUID->"c472b477-a0ea-4a21-8afa-\
1e0101e5d727"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PolandLemma22", "[", 
   RowBox[{"c6_", ",", "m_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{"c6", "/", 
         RowBox[{"2", "^", "n"}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"2", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "4"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.886303098200499*^9, 3.886303176740327*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"bf3cb2c0-75a7-4967-afad-b32629b6ea9e"]
}, Closed]],

Cell[CellGroupData[{

Cell["Vision", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, 
   3.990667957557056*^9, {3.99067246543884*^9, 
   3.990672466608118*^9}},ExpressionUUID->"9fe53b82-df73-4cd8-870b-\
c44644c27433"],

Cell["\<\
Vision[P, u]
Factors the polynomial or expression P.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
 This is a diagnostic helper function for inspecting the coefficients of the \
factors of P.
  The function uses FactorList, which is safer than applying List directly to \
Factor[P], because it avoids splitting irreducible sums into terms.\
\>", "Text",
 CellChangeTimes->{
  3.990668503318449*^9, {3.9906686471060133`*^9, 3.9906686674900217`*^9}, {
   3.990672476810256*^9, 
   3.990672477733142*^9}},ExpressionUUID->"9fc47bca-9cd4-4fe7-8c44-\
45cdcf0d51c8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Vision", "[", 
   RowBox[{"P_", ",", "u_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"L", "=", 
     RowBox[{"Factor", "[", "P", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "<=", 
       RowBox[{"Length", "@", "L"}]}], ",", 
      RowBox[{"i", "++"}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"i", ",", "\"\< <---> \>\"", ",", 
         RowBox[{"L", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", " ", 
       RowBox[{"Print", "@", 
        RowBox[{"MatrixForm", "@", 
         RowBox[{"Transpose", "@", 
          RowBox[{"{", 
           RowBox[{"CoefficientList", "[", 
            RowBox[{
             RowBox[{"L", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", "u"}], "]"}], 
           "}"}]}]}]}]}]}], "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886401267026865*^9, 3.8864012679454947`*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"7c6acf48-d788-43bb-9442-2e6241c98795"]
}, Closed]],

Cell[CellGroupData[{

Cell["VisionMod", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990672485630422*^9, 
   3.990672486506579*^9}},ExpressionUUID->"ac044cff-0690-4d2b-8da3-\
f4bcef31864b"],

Cell["\<\
AyudaMod[P, u, p]
First reduces P modulo p and factors the result.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
This is useful for studying the factorization and coefficients of P modulo p.\
\
\>", "Text",
 CellChangeTimes->{
  3.990668506896264*^9, {3.990668672078745*^9, 
   3.990668680314468*^9}},ExpressionUUID->"5518e2bd-8f0b-461a-a69b-\
123ff90bcd48"],

Cell[BoxData[
 RowBox[{
  RowBox[{"VisionMod", "[", 
   RowBox[{"P_", ",", " ", "u_", ",", " ", "p_"}], "]"}], " ", ":=", "\n", 
  "  ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"L", ",", " ", "Q", ",", " ", "i"}], "}"}], ",", "\n", "    ", 
    RowBox[{
     RowBox[{"Q", " ", "=", " ", 
      RowBox[{"PolynomialMod", "[", 
       RowBox[{"P", ",", " ", "p"}], "]"}]}], ";", "\n", "    ", 
     RowBox[{"L", " ", "=", " ", 
      RowBox[{
       RowBox[{"FactorList", "[", "Q", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"2", " ", ";;"}], ",", " ", "1"}], "]"}], "]"}]}], ";", "\n",
      "    ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"L", " ", "===", " ", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"L", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{"Factor", "[", "Q", "]"}], "}"}]}]}], "  ", "]"}], ";", "\n",
      "    ", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", " ", "=", " ", "1"}], ",", " ", 
       RowBox[{"i", " ", "<=", " ", 
        RowBox[{"Length", "[", "L", "]"}]}], ",", " ", 
       RowBox[{"i", "++"}], ",", "  ", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"i", ",", " ", "\"\< <---> \>\"", ",", " ", 
          RowBox[{"L", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", " ", "@", " ", 
         RowBox[{"MatrixForm", " ", "@", " ", 
          RowBox[{"Transpose", " ", "@", " ", 
           RowBox[{"{", 
            RowBox[{"CoefficientList", "[", 
             RowBox[{
              RowBox[{"L", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", " ", "u"}], "]"}], 
            "}"}]}]}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], 
   "\[IndentingNewLine]", " ", "]"}]}]], "Input",
 CellChangeTimes->{{3.9906724917628393`*^9, 3.990672529367728*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"fab5ba90-9be0-4def-87ff-94e91bebc634"]
}, Closed]],

Cell[CellGroupData[{

Cell["powerPrime", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, 
   3.990668002047792*^9},ExpressionUUID->"90ae618c-8fb4-4451-b91a-\
e6401efa118b"],

Cell["\<\
powerPrime[n, p]
Computes the exponent of the prime p in the prime factorization of n.
 In other words, it returns the p - adic valuation v_p (n).\
\>", "Text",
 CellChangeTimes->{
  3.990668512216362*^9, {3.990668685634695*^9, 
   3.990668705264998*^9}},ExpressionUUID->"d7ef8a42-9194-4db9-b248-\
1b4ee8dd835c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"powerPrime", "[", 
   RowBox[{"n_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "f", "}"}], ",", 
    RowBox[{
     RowBox[{"f", "=", 
      RowBox[{"FactorInteger", "[", "n", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"k", "=", 
      RowBox[{"Cases", "[", 
       RowBox[{"f", ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"p", ",", "k_"}], "}"}], "\[RuleDelayed]", "k"}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"k", "\[Equal]", 
        RowBox[{"{", "}"}]}], ",", "0", ",", 
       RowBox[{"k", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8872517996742373`*^9, 3.887251812890751*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"9baef9ae-266c-4a67-92a9-6c31a4f1ba47"]
}, Closed]],

Cell[CellGroupData[{

Cell["pIntegralModel", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990668014657935*^9, 
   3.990668018277915*^9}},ExpressionUUID->"6370f8f4-9f62-4902-91a4-\
f6ad69d6a2ad"],

Cell["\<\
pIntegralModel[M, p]
Checks whether the Weierstrass coefficients associated to the invariant \
triple M are p - integral.
The input M is expected to be a list of the form
      M = {c4, c6, Delta}.
The corresponding Weierstrass coefficients are computed as
    a4 = -M[[1]]/48,
    a6 = -M[[2]]/864.
 The function then checks whether the denominators of a4 and a6 are divisible \
by p.
 It returns True if both coefficients are p - integral.
 If at least one coefficient is not p - integral, it prints {a4, a6} and \
returns False.\
\>", "Text",
 CellChangeTimes->{
  3.990668515099354*^9, {3.990668711294724*^9, 
   3.990668748113006*^9}},ExpressionUUID->"79f094ed-7aa3-4ed0-bc17-\
eff5e36d452c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pIntegralModel", "[", 
   RowBox[{"M_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"F", ",", "L"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"F", "=", 
      RowBox[{"Factor", "@", 
       RowBox[{"Refine", "@", 
        RowBox[{"PowerExpand", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{"M", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], "/", "48"}], ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"M", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "/", "864"}]}], "}"}], 
         "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"L", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"powerPrime", "[", 
         RowBox[{
          RowBox[{"Denominator", "@", 
           RowBox[{"F", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", "p"}], "]"}], ",", 
        RowBox[{"powerPrime", "[", 
         RowBox[{
          RowBox[{"Denominator", "@", 
           RowBox[{"F", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", "p"}], "]"}]}], "}"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"L", "\[Equal]", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], ",", "True", ",", " ", 
       RowBox[{
        RowBox[{"Print", "[", "L", "]"}], ";", "False"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.8872080410140142`*^9, 3.8872081043152437`*^9}, {
  3.887208226545286*^9, 3.887208239810857*^9}, {3.887208283031227*^9, 
  3.887208385892682*^9}, {3.8872514232683887`*^9, 3.887251491833002*^9}, {
  3.887251557834517*^9, 3.8872515674537363`*^9}, {3.887251831685504*^9, 
  3.8872518580315332`*^9}, {3.887251912020729*^9, 3.8872520142963457`*^9}, {
  3.887252068933837*^9, 3.887252093188457*^9}, {3.887252292695537*^9, 
  3.887252335330195*^9}, {3.9906725807675543`*^9, 3.9906725819134483`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"1286aa29-4a74-4792-9e97-4415715ce781"]
}, Closed]],

