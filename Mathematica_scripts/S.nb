Cell[CellGroupData[{

Cell["PositivePower", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9},ExpressionUUID->"b9c8767f-f0e6-458f-a491-\
3e09e82eb050"],

Cell["\<\
Replaces t by p^m*u in the invariants {c4, c6, Delta}, assuming m > 0.
 The resulting expressions are power - expanded, refined under the assumption \
m > 0, and factored.
 This is useful for studying the behaviour of the invariants under the
 substitution t = p^m u, for positive powers of p.\
\>", "Text",
 CellChangeTimes->{{3.99066742936615*^9, 3.990667461814023*^9}, {
  3.990667541132284*^9, 
  3.990667541704321*^9}},ExpressionUUID->"2e4e9f91-2bcd-4aee-9752-\
306ca6e8fa79"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PositivePower", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"PowerExpand", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
       RowBox[{"t", "\[Rule]", 
        RowBox[{
         RowBox[{"p", "^", "m"}], "*", "u"}]}]}], ",", 
      RowBox[{"Assumptions", "\[Rule]", 
       RowBox[{"m", ">", "0"}]}]}], "]"}], "//", "Refine"}], "//", 
   "Factor"}]}]], "Input",
 CellChangeTimes->{{3.886252437665538*^9, 3.886252438649626*^9}, 
   3.886252966474904*^9, {3.8862534977113247`*^9, 3.886253572623859*^9}, 
   3.886253663508657*^9, {3.886303774189517*^9, 3.886303798869195*^9}, {
   3.886303887860013*^9, 3.8863039781520557`*^9}, {3.886304023287404*^9, 
   3.886304065680294*^9}, {3.886304123162631*^9, 3.886304146399413*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"d25c7461-ff63-4e72-b303-844c4c802abe"]
}, Closed]],

Cell[CellGroupData[{

Cell["NegativePower ", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667834522991*^9, 
   3.990667845042171*^9}},ExpressionUUID->"b590651b-583e-4981-b287-\
592faecaea03"],

Cell["\<\
NegativePower[c4, c6, Delta, p]
 Replaces t by p^(-m)*u in the invariants {c4, c6, Delta}, assuming m > 0.
 The resulting expressions are power - expanded, refined under the assumption \
m > 0, and factored.
 This is useful for studying the behaviour of the invariants under the  \
substitution t = p^(-m) u.\
\>", "Text",
 CellChangeTimes->{
  3.99066806174842*^9, {3.990668098232123*^9, 
   3.990668115556229*^9}},ExpressionUUID->"f94f888b-682c-4118-940c-\
a2367c04fc11"],

Cell[BoxData[
 RowBox[{
  RowBox[{"NegativePower", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"PowerExpand", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
       RowBox[{"t", "\[Rule]", 
        RowBox[{
         RowBox[{"p", "^", 
          RowBox[{"-", "m"}]}], "*", "u"}]}]}], ",", 
      RowBox[{"Assumptions", "\[Rule]", 
       RowBox[{"m", ">", "0"}]}]}], "]"}], "//", "Refine"}], "//", 
   "Factor"}]}]], "Input",
 CellChangeTimes->{{3.883822720420061*^9, 3.883822742251875*^9}, {
  3.886252357843708*^9, 3.886252374960618*^9}, {3.886252939674118*^9, 
  3.886252963201332*^9}, {3.886253103804723*^9, 3.8862531044520082`*^9}, {
  3.886253527915574*^9, 3.886253565858328*^9}, {3.886253631838805*^9, 
  3.886253633108219*^9}, {3.886253668128891*^9, 3.88625367066061*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"e4c635b5-e9b4-4e63-8a61-5da267d8de03"]
}, Closed]],

Cell[CellGroupData[{

Cell["SpecificPower", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, 
   3.990667847976283*^9},ExpressionUUID->"03779f9e-0500-425e-9251-\
49cb7391636a"],

Cell["\<\
SpecificPower[c4, c6, Delta, p, m]
Replaces t by p^m*u for a specified exponent m.
The resulting triple {c4, c6, Delta} is power - expanded, refined, and \
factored.
Unlike PositivePower and NegativePower, here m is given as an explicit \
argument of the function.\
\>", "Text",
 CellChangeTimes->{
  3.990668091041304*^9, {3.990668124242468*^9, 
   3.9906681365823298`*^9}},ExpressionUUID->"b6e253d8-7a74-41f6-a15f-\
f35cb72edcd2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SpecificPower", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_", ",", "m_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"PowerExpand", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
      RowBox[{"t", "\[Rule]", 
       RowBox[{
        RowBox[{"p", "^", "m"}], "*", "u"}]}]}], "]"}], "//", "Refine"}], "//",
    "Factor"}]}]], "Input",
 CellChangeTimes->{{3.886253599799819*^9, 3.886253616995083*^9}, 
   3.886256283304056*^9},
 CellLabel->"In[3]:=",ExpressionUUID->"8f319362-783d-481d-9061-ae8c1e7ef223"]
}, Closed]],

Cell[CellGroupData[{

Cell["PositivePowerPrint", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, 
   3.990667865470902*^9},ExpressionUUID->"dcec7f9d-3b0e-41ca-80bc-\
d9600dd4bf1e"],

Cell["\<\
PositivePowerPrint[c4, c6, Delta, p]
 Performs the same substitution as PositivePower, namely t = p^m u with m > \
0.
 In addition, it prints the corresponding Weierstrass coefficients
    a4 = -c4/48,
    a6 = -c6/864.
 It returns the transformed and factored triple {c4, c6, Delta}.\
\>", "Text",
 CellChangeTimes->{{3.990668424631196*^9, 
  3.990668441503735*^9}},ExpressionUUID->"f0fa4258-e8a9-4dc9-b62a-\
c597f293845a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PositivePowerPrint", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"Factor", "@", 
      RowBox[{"Refine", "@", 
       RowBox[{"PowerExpand", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
          RowBox[{"t", "\[Rule]", 
           RowBox[{
            RowBox[{"p", "^", "m"}], "*", "u"}]}]}], ",", 
         RowBox[{"Assumptions", "\[Rule]", 
          RowBox[{"m", ">", "0"}]}]}], "]"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<c4=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "/", "48"}]}], ",", 
       RowBox[{"\"\<c6=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "/", "864"}]}]}], "}"}], "]"}], ";",
     "\[IndentingNewLine]", " ", 
    RowBox[{"Return", "[", "M", "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886304132968459*^9, 3.886304133672339*^9}, {
  3.8864242890954514`*^9, 3.886424295644353*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"79041632-97e4-4aca-8639-564943439766"]
}, Closed]],

