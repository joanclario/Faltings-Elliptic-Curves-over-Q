0.
It also prints the corresponding Weierstrass coefficients  
    a4 = -c4/48,
    a6 = -c6/864.
 It returns the transformed and factored triple {c4, c6, Delta}.\
\>", "Text",
 CellChangeTimes->{
  3.990668479549239*^9, {3.990668528820611*^9, 
   3.990668553377615*^9}},ExpressionUUID->"f927d268-e044-4f2b-b0cc-\
e576cc21662d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"NegativePowerPrint", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"Factor", "@", 
      RowBox[{"Refine", "@", 
       RowBox[{"PowerExpand", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
          RowBox[{"t", "\[Rule]", 
           RowBox[{
            RowBox[{"p", "^", 
             RowBox[{"-", "m"}]}], "*", "u"}]}]}], ",", 
         RowBox[{"Assumptions", "\[Rule]", 
          RowBox[{"m", ">", "0"}]}]}], "]"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<c4=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "/", "48"}]}], ",", 
       RowBox[{"\"\<c6=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "/", "864"}]}]}], "}"}], "]"}], ";",
     "\[IndentingNewLine]", " ", 
    RowBox[{"Return", "[", "M", "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886304161576004*^9, 3.886304167426662*^9}, {
  3.886424276958407*^9, 3.886424286936861*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"a2e77de1-13a9-41d4-b933-637d04ee7632"]
}, Closed]],

