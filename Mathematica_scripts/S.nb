Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", 
   TagBox[GridBox[{
      {
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "3"}], "+", 
          RowBox[{
           SuperscriptBox["p", 
            RowBox[{"2", " ", "m"}]], " ", 
           SuperscriptBox["u", "2"]}]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "3"}], "+", 
          RowBox[{"3", " ", 
           SuperscriptBox["p", 
            RowBox[{"2", " ", "m"}]], " ", 
           SuperscriptBox["u", "2"]}], "-", 
          RowBox[{"9", " ", 
           SuperscriptBox["p", 
            RowBox[{"4", " ", "m"}]], " ", 
