Cell["\<\
SpecificPowerPrint[c4, c6, Delta, p, m]
Replaces t by p^m*u for a specified exponent m.
It prints the associated Weierstrass coefficients
    a4 = -c4/48,
    a6 = -c6/864,
and returns the transformed and factored triple {c4, c6, Delta}.\
\>", "Text",
 CellChangeTimes->{
  3.990668485703532*^9, {3.990668559439372*^9, 
   3.9906685680455847`*^9}},ExpressionUUID->"5ff6676c-d103-4379-bfa3-\
3324240c0497"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SpecificPowerPrint", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"Factor", "@", 
      RowBox[{"Refine", "@", 
       RowBox[{"PowerExpand", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
         RowBox[{"t", "\[Rule]", 
          RowBox[{
           RowBox[{"p", "^", "m"}], "*", "u"}]}]}], "]"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<c4=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "/", "48"}]}], ",", 
       RowBox[{"\"\<c6=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "/", "864"}]}]}], "}"}], "]"}], ";",
     "\[IndentingNewLine]", " ", 
    RowBox[{"Return", "[", "M", "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886304183922884*^9, 3.886304218856881*^9}, {
  3.8864242640941772`*^9, 3.886424274426693*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"85e7391f-0ba3-48ba-a65c-501a87d7262a"]
}, Closed]],

Cell[CellGroupData[{

Cell["Twist", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.9906679078802147`*^9}},ExpressionUUID->"989f13e4-56ea-4b3f-a7c5-\
d5543b7a6b9f"],

Cell["\<\
Twist[{c4, c6, Delta}, s]
 Applies the standard scaling transformation to the invariants of an elliptic \
curve.
 Under a change of variables with scaling factor s, the invariants transform as
    c4    -> c4/s^4,
    c6    -> c6/s^6,
    Delta -> Delta/s^12.
 The resulting expressions are power - expanded, refined, and factored.\
\>", "Text",
 CellChangeTimes->{
  3.9906684897516203`*^9, {3.9906685763156033`*^9, 
   3.99066859000504*^9}},ExpressionUUID->"0519dafb-c488-4b98-86db-\
bde37919ac31"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Twist", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"c4_", ",", "c6_", ",", "Delta_"}], "}"}], ",", "s_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"PowerExpand", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"c4", "/", 
        RowBox[{"s", "^", "4"}]}], ",", 
       RowBox[{"c6", "/", 
        RowBox[{"s", "^", "6"}]}], ",", 
       RowBox[{"Delta", "/", 
        RowBox[{"s", "^", "12"}]}]}], "}"}], "]"}], "//", "Refine"}], "//", 
   "Factor"}]}]], "Input",
 CellChangeTimes->{{3.8862536998964443`*^9, 3.886253769114563*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"398d66d1-023d-49dc-8e80-a6d18bc1ebc4"]
}, Closed]],

Cell[CellGroupData[{

Cell["CuentaP2 ", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.9906679276567574`*^9}},ExpressionUUID->"e72fd10f-95eb-42a4-884a-\
b1b289d67418"],

Cell["\<\
CuentaP2[c4, c6, m]
Computes the congruence expression
   (c6/3^3)^2 + 2 - 3 c4/3^2
after the substitution t = 3^m u.
The expression is power - expanded, refined, factored, and then reduced \
modulo 9.
This function is intended to check a local congruence condition at p = 3.\
\[LineSeparator]Condition P2 in Papadopoulus\[CloseCurlyQuote]s paper for p=3 \
(Section II.2, Tableaus II)\
\>", "Text",
 CellChangeTimes->{{3.990668254622575*^9, 3.990668255780031*^9}, 
   3.990668492990816*^9, {3.990668598544017*^9, 3.990668605585143*^9}, {
   3.990672598122566*^9, 3.990672625986929*^9}, {3.990672681549316*^9, 
   3.990672696935503*^9}, {3.990672770157649*^9, 
   3.990672775668046*^9}},ExpressionUUID->"42688bbe-41ce-4323-bf85-\
52161eec5fca"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CuentaP2", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c6", "/", 
            RowBox[{"3", "^", "3"}]}], ")"}], "^", "2"}], "+", "2", "-", 
         RowBox[{"3", " ", 
          RowBox[{"c4", "/", 
           RowBox[{"3", "^", "2"}]}]}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"3", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "9"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.990672383534123*^9},
 CellLabel->"In[8]:=",ExpressionUUID->"80a6676d-569c-4005-a269-f744b2768f19"]
}, Closed]],

Cell[CellGroupData[{

Cell["CuentaP5", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.990667934470553*^9}},ExpressionUUID->"0fe6bf10-bc8a-4372-a115-\
ac53d5896424"],

Cell["\<\
CuentaP5[c4, c6, m]
Computes the congruence expression
      (c6/3^6)^2 + 2 - 3 c4/3^4
after the substitution t = 3^m u.
The expression is power - expanded, refined, factored, and then reduced \
modulo 9.
This function is intended to check a related local congruence condition at p \
= 3.
Condition P5 in Papadopoulus\[CloseCurlyQuote]paper for p=3 (Section II.2, \
Tableaus II)\
\>", "Text",
 CellChangeTimes->{
  3.990668495850008*^9, {3.990668608689356*^9, 3.990668629771914*^9}, {
   3.990672631848387*^9, 3.990672635188414*^9}, 3.990672703406727*^9, {
   3.9906727651735888`*^9, 
   3.990672766140173*^9}},ExpressionUUID->"847312e5-3a99-48c2-828f-\
9300f886cc78"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CuentaP5", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c6", "/", 
            RowBox[{"3", "^", "6"}]}], ")"}], "^", "2"}], "+", "2", "-", 
         RowBox[{"3", " ", 
          RowBox[{"c4", "/", 
           RowBox[{"3", "^", "4"}]}]}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"3", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "9"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.99067240018237*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"905fb710-e113-4233-a6b6-30bb2a22f25a"]
}, Closed]],

Cell[CellGroupData[{

Cell["PolandLemma22", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, 
   3.990667946386627*^9},ExpressionUUID->"563f1ed2-ca07-4150-9bd3-\
82fb5a8c5cbb"],

Cell["\<\
PolandLemma22[c6, m, n]
Computes c6/2^n after the substitution t = 2^m u.
The expression is power - expanded, refined, factored, and reduced modulo 4.
This appears to be designed to verify a congruence condition related to Lemma \
2.2 in Browkin & Davies\[CloseCurlyQuote] paper.\
\>", "Text",
 CellChangeTimes->{
  3.990668499775419*^9, {3.990668633753881*^9, 3.990668643091579*^9}, {
   3.9906727441943703`*^9, 
   3.99067275898619*^9}},ExpressionUUID->"07b2b0d3-d458-45c0-ab6e-\
61b3df60a93b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PolandLemma22", "[", 
   RowBox[{"c6_", ",", "m_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{"c6", "/", 
         RowBox[{"2", "^", "n"}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"2", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "4"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.886303098200499*^9, 3.886303176740327*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"230b44d4-e8d4-47f7-ab0c-d3c188bd4534"]
}, Closed]],

Cell[CellGroupData[{

Cell["Vision", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, 
   3.990667957557056*^9, {3.99067246543884*^9, 
   3.990672466608118*^9}},ExpressionUUID->"2a482c04-4216-4630-863a-\
866bd36ab310"],

Cell["\<\
Vision[P, u]
Factors the polynomial or expression P.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
 This is a diagnostic helper function for inspecting the coefficients of the \
factors of P.
  The function uses FactorList, which is safer than applying List directly to \
Factor[P], because it avoids splitting irreducible sums into terms.\
\>", "Text",
 CellChangeTimes->{
  3.990668503318449*^9, {3.9906686471060133`*^9, 3.9906686674900217`*^9}, {
   3.990672476810256*^9, 
   3.990672477733142*^9}},ExpressionUUID->"6c3b156b-6b19-4679-a8d8-\
cebd40d0e64d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Vision", "[", 
   RowBox[{"P_", ",", "u_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"L", "=", 
     RowBox[{"Factor", "[", "P", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "<=", 
       RowBox[{"Length", "@", "L"}]}], ",", 
      RowBox[{"i", "++"}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"i", ",", "\"\< <---> \>\"", ",", 
         RowBox[{"L", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", " ", 
       RowBox[{"Print", "@", 
        RowBox[{"MatrixForm", "@", 
         RowBox[{"Transpose", "@", 
          RowBox[{"{", 
           RowBox[{"CoefficientList", "[", 
            RowBox[{
             RowBox[{"L", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", "u"}], "]"}], 
           "}"}]}]}]}]}]}], "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886401267026865*^9, 3.8864012679454947`*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"fd421a5f-8015-4e9a-afd0-4a28c60fa6a0"]
}, Closed]],

Cell[CellGroupData[{

Cell["VisionMod", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990672485630422*^9, 
   3.990672486506579*^9}},ExpressionUUID->"d8bdd425-8b16-4daf-bc5b-\
b6a0eba049e6"],

Cell["\<\
AyudaMod[P, u, p]
First reduces P modulo p and factors the result.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
This is useful for studying the factorization and coefficients of P modulo p.\
\
\>", "Text",
 CellChangeTimes->{
  3.990668506896264*^9, {3.990668672078745*^9, 
   3.990668680314468*^9}},ExpressionUUID->"bb8fb1b4-709a-4204-95d9-\
5e210cbe0dfb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"VisionMod", "[", 
   RowBox[{"P_", ",", " ", "u_", ",", " ", "p_"}], "]"}], " ", ":=", "\n", 
  "  ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"L", ",", " ", "Q", ",", " ", "i"}], "}"}], ",", "\n", "    ", 
    RowBox[{
     RowBox[{"Q", " ", "=", " ", 
      RowBox[{"PolynomialMod", "[", 
       RowBox[{"P", ",", " ", "p"}], "]"}]}], ";", "\n", "    ", 
     RowBox[{"L", " ", "=", " ", 
      RowBox[{
       RowBox[{"FactorList", "[", "Q", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"2", " ", ";;"}], ",", " ", "1"}], "]"}], "]"}]}], ";", "\n",
      "    ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"L", " ", "===", " ", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"L", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{"Factor", "[", "Q", "]"}], "}"}]}]}], "  ", "]"}], ";", "\n",
      "    ", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", " ", "=", " ", "1"}], ",", " ", 
       RowBox[{"i", " ", "<=", " ", 
        RowBox[{"Length", "[", "L", "]"}]}], ",", " ", 
       RowBox[{"i", "++"}], ",", "  ", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"i", ",", " ", "\"\< <---> \>\"", ",", " ", 
          RowBox[{"L", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", " ", "@", " ", 
         RowBox[{"MatrixForm", " ", "@", " ", 
          RowBox[{"Transpose", " ", "@", " ", 
           RowBox[{"{", 
            RowBox[{"CoefficientList", "[", 
             RowBox[{
              RowBox[{"L", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", " ", "u"}], "]"}], 
            "}"}]}]}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], 
   "\[IndentingNewLine]", " ", "]"}]}]], "Input",
 CellChangeTimes->{{3.9906724917628393`*^9, 3.990672529367728*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"c8107b59-edab-404d-9fba-f1db9b6226b2"]
}, Closed]],

Cell[CellGroupData[{

Cell["powerPrime", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, 
   3.990668002047792*^9},ExpressionUUID->"2d492a32-406c-4c12-8c5f-\
4468021d1467"],

Cell["\<\
powerPrime[n, p]
Computes the exponent of the prime p in the prime factorization of n.
 In other words, it returns the p - adic valuation v_p (n).\
\>", "Text",
 CellChangeTimes->{
  3.990668512216362*^9, {3.990668685634695*^9, 
   3.990668705264998*^9}},ExpressionUUID->"ab723e31-eedb-4444-804a-\
71d50595130b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"powerPrime", "[", 
   RowBox[{"n_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "f", "}"}], ",", 
    RowBox[{
     RowBox[{"f", "=", 
      RowBox[{"FactorInteger", "[", "n", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"k", "=", 
      RowBox[{"Cases", "[", 
       RowBox[{"f", ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"p", ",", "k_"}], "}"}], "\[RuleDelayed]", "k"}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"k", "\[Equal]", 
        RowBox[{"{", "}"}]}], ",", "0", ",", 
       RowBox[{"k", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8872517996742373`*^9, 3.887251812890751*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"ec6686a9-c2a3-4682-bc99-b7b19cd10e4b"]
}, Closed]],

Cell[CellGroupData[{

Cell["pIntegralModel", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990668014657935*^9, 
   3.990668018277915*^9}},ExpressionUUID->"526deab9-5bdb-4315-89ac-\
118fab6f14d2"],

Cell["\<\
pIntegralModel[M, p]
Checks whether the Weierstrass coefficients associated to the invariant \
triple M are p - integral.
The input M is expected to be a list of the form
      M = {c4, c6, Delta}.
The corresponding Weierstrass coefficients are computed as
    a4 = -M[[1]]/48,
    a6 = -M[[2]]/864.
 The function then checks whether the denominators of a4 and a6 are divisible \
by p.
 It returns True if both coefficients are p - integral.
 If at least one coefficient is not p - integral, it prints {a4, a6} and \
returns False.\
\>", "Text",
 CellChangeTimes->{
  3.990668515099354*^9, {3.990668711294724*^9, 
   3.990668748113006*^9}},ExpressionUUID->"32830bdb-b40e-4379-9209-\
d7ab8b53f442"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pIntegralModel", "[", 
   RowBox[{"M_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"F", ",", "L"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"F", "=", 
      RowBox[{"Factor", "@", 
       RowBox[{"Refine", "@", 
        RowBox[{"PowerExpand", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{"M", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], "/", "48"}], ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"M", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "/", "864"}]}], "}"}], 
         "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"L", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"powerPrime", "[", 
         RowBox[{
          RowBox[{"Denominator", "@", 
           RowBox[{"F", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", "p"}], "]"}], ",", 
        RowBox[{"powerPrime", "[", 
         RowBox[{
          RowBox[{"Denominator", "@", 
           RowBox[{"F", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", "p"}], "]"}]}], "}"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"L", "\[Equal]", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], ",", "True", ",", " ", 
       RowBox[{
        RowBox[{"Print", "[", "L", "]"}], ";", "False"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.8872080410140142`*^9, 3.8872081043152437`*^9}, {
  3.887208226545286*^9, 3.887208239810857*^9}, {3.887208283031227*^9, 
  3.887208385892682*^9}, {3.8872514232683887`*^9, 3.887251491833002*^9}, {
  3.887251557834517*^9, 3.8872515674537363`*^9}, {3.887251831685504*^9, 
  3.8872518580315332`*^9}, {3.887251912020729*^9, 3.8872520142963457`*^9}, {
  3.887252068933837*^9, 3.887252093188457*^9}, {3.887252292695537*^9, 
  3.887252335330195*^9}, {3.9906725807675543`*^9, 3.9906725819134483`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"e235d6eb-c1e8-48e0-a0a4-0c1a010a0e89"]
}, Closed]],

Cell[CellGroupData[{

Cell["aInvariants", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990668014657935*^9, 
   3.990668018277915*^9}, 
   3.991049666438471*^9},ExpressionUUID->"39222b66-4bb6-4ae8-b27d-\
fca37cb6fa5e"],

Cell["\<\
aInvariants[c4,c6]
Given the c-invariants c4 and c6 of an elliptic curve E,   
this function returns the corresponding coefficients {a4, a6}  of the short \
Weierstrass equation 
  y^2 = x^3 + a4 x + a6
using the relations
   a4 = -c4/48,
   a6 = -c6/864.\
\>", "Text",
 CellChangeTimes->{
  3.990668515099354*^9, {3.990668711294724*^9, 3.990668748113006*^9}, {
   3.991049684125448*^9, 3.991049688373836*^9}, {3.99104991174494*^9, 
   3.9910500573305283`*^9}, {3.991050235804418*^9, 
   3.991050278812703*^9}},ExpressionUUID->"f26c2e29-eb56-447a-8ca9-\
cefc0895e05a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"aInvariants", "[", 
   RowBox[{"c4_", ",", "c6_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "c4"}], "/", "48"}], ",", 
    RowBox[{
     RowBox[{"-", "c6"}], "/", "864"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.991049681538488*^9, 3.991049758442471*^9}, {
  3.9910500946855*^9, 3.9910500974481287`*^9}, {3.991050241722801*^9, 
  3.991050245677408*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"0838ada6-2f3f-430c-bc34-5917f1e2cd5a"]
}, Closed]]
}, Closed]],

