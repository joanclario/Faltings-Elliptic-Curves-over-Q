Cell[TextData[{
 "This notebook contains the detailed computations underlying the isogeny \
graph of type L",
 Cell[BoxData[
  FormBox[
   SubscriptBox["", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5dd1a00c-e9d5-4b3d-9de8-c067661079f6"],
 "(13), as well as the results presented in the file Faltings_types.pdf, \
which accompanies the manuscript \[OpenCurlyDoubleQuote]Faltings elliptic \
curves in twisted Q-isogeny classes\[CloseCurlyDoubleQuote], by Enrique Gonz\
\[AAcute]lez-Jim\[EAcute]nez and Joan-C. Lario (arXiv:2509.23283), as \
supplementary material. "
}], "Text",
 CellChangeTimes->{{3.991227456173464*^9, 3.9912274629362288`*^9}, {
   3.991236032992955*^9, 3.9912360605492992`*^9}, {3.991236104172037*^9, 
