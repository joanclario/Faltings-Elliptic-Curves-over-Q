Cell[TextData[{
 "Therefore, to obtain a 2-integral model, we make the change of variables \
with u = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{"m", "+", "1"}], ")"}]}]], " "}], TraditionalForm]],
  ExpressionUUID->"193bcb82-52db-4178-adbc-cd0c5fb0d333"],
 ", which also gives a 2-minimal model"
}], "Text",
