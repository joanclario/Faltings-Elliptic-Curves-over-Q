   RowBox[{"4096", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"2", " ", "v"}]}], ")"}], "9"], " ", 
    RowBox[{"(", 
     RowBox[{"37", "+", 
      RowBox[{"22", " ", "v"}], "+", 
      RowBox[{"4", " ", 
       SuperscriptBox["v", "2"]}]}], ")"}]}]}], "}"}]], "Output",
 CellChangeTimes->{{3.886270616375391*^9, 3.886270625759387*^9}, {
   3.886270657881868*^9, 3.8862706849666243`*^9}, 3.88627094812941*^9, 
   3.886303379946855*^9, 3.88630370701514*^9, 3.9910506303831587`*^9},
 CellLabel->
  "Out[191]=",ExpressionUUID->"deb58073-2e04-491f-80c2-d0686e4c1dab"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
