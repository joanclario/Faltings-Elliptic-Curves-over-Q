with u = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["p", 
    RowBox[{"-", "m"}]], TraditionalForm]],ExpressionUUID->
  "4ac3ed62-2cc3-44fc-98ae-998338a4b7df"],
