 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["sig", "2"], "(", 
    SubscriptBox["E", "1"]}], TraditionalForm]],ExpressionUUID->
  "00b08b66-3685-4f2e-8315-c804569cc563"],
 ") = (\[GreaterEqual]8, 9, 12)\[LineSeparator]We still need to ckeck if it \
is 2-minimal. "
}], "Text",
 CellChangeTimes->{{3.99122896618406*^9, 3.991229001351944*^9}, {
   3.991229165199553*^9, 3.991229183487967*^9}, 3.991229495930871*^9, {
