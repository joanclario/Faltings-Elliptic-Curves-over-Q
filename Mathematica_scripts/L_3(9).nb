Cell[TextData[{
 "Therefore, to obtain a 2-integral model, we make the change of variables \
with u = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "f886925b-d8de-4dd4-9430-2823415e11fe"],
 ". \[LineSeparator]Moreover, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["sig", "2"], "(", 
    SubscriptBox["E", "9"]}], TraditionalForm]],ExpressionUUID->
  "576ca954-e0ce-47b6-a26b-fdb74cd974ad"],
 ") = (\[GreaterEqual]8, 9, 12)\[LineSeparator]We still need to ckeck if it \
is 2-minimal. "
}], "Text",
 CellChangeTimes->{{3.99122896618406*^9, 3.991229001351944*^9}, {
   3.991229165199553*^9, 3.991229183487967*^9}, 3.991229495930871*^9, {
   3.991232198643416*^9, 3.991232245354739*^9}, {3.991233099930826*^9, 
   3.991233100343877*^9}},ExpressionUUID->"154cab36-bba6-4634-b95a-\
a9717b8724d1"],

Cell["\<\
It remains to check whether the model is 2-minimal. For this purpose, we \
apply Lemma 2.2 from the article by Br\[ODoubleDot]ker and Davies.\
\>", "Text",
 CellChangeTimes->{{3.886253067240425*^9, 3.886253080376199*^9}, {
   3.886253135456211*^9, 3.886253138598402*^9}, {3.8862539742225037`*^9, 
   3.886253995011887*^9}, {3.886270110924708*^9, 3.8862701187236032`*^9}, {
   3.886270719250597*^9, 3.886270773495248*^9}, {3.886303293021015*^9, 
   3.886303321668022*^9}, 3.9912231158556757`*^9, 3.991232223272985*^9, {
   3.991232283755774*^9, 
   3.9912322908170567`*^9}},ExpressionUUID->"85ee5ea3-e711-4de4-ac9a-\
a5a134bb550c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"PolandLemma22", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"M", "[", 
     RowBox[{"[", "2", "]"}], "]"}], "/.", 
    RowBox[{"{", 
     RowBox[{"u", "\[Rule]", 
      RowBox[{"1", "+", 
       RowBox[{"v", " ", "2"}]}]}], "}"}]}], ",", "0", ",", "9"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.886303228131866*^9, 3.8863032308567867`*^9}, {
  3.886303263134214*^9, 3.8863032789120007`*^9}},
 CellLabel->
  "In[147]:=",ExpressionUUID->"33b018e7-572d-48bf-817f-52a47a33145e"],

Cell[BoxData["3"], "Output",
 CellChangeTimes->{{3.886303266918124*^9, 3.886303280288913*^9}, 
   3.991050530387722*^9},
 CellLabel->
  "Out[147]=",ExpressionUUID->"363176c1-c63a-48ac-bcf7-0f633706b7ca"]
}, Open  ]],

Cell[TextData[{
 "Since the result is equal to 3, it is a 2-minimal model, and the Kodaira \
type is ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["II", "*"], TraditionalForm]],ExpressionUUID->
  "60bf4bb9-cfe2-49c0-92ea-e2ac97fc98dd"],
 "."
}], "Text",
