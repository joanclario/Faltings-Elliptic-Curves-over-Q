    SubscriptBox["E", "3"]}], TraditionalForm]],ExpressionUUID->
  "8e5e8994-57a4-4331-aca2-4b937383ff46"],
 ") = (\[GreaterEqual]8, 9, 12)\[LineSeparator]We still need to ckeck if it \
is 2-minimal. "
}], "Text",
