Cell[TextData[{
 "Therefore, to obtain a 2-integral model, we make the change of variables \
with u = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "fb32995b-8fca-49ca-84b7-d96ffab85215"],
