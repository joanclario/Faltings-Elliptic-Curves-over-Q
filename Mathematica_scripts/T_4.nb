   3.990667773024621*^9, {3.990667884593225*^9, 
   3.990667934470553*^9}},ExpressionUUID->"07dd5638-ab54-434b-9635-\
42a4eec320ab"],

Cell["\<\
CuentaP5[c4, c6, m]
Computes the congruence expression
      (c6/3^6)^2 + 2 - 3 c4/3^4
after the substitution t = 3^m u.
The expression is power - expanded, refined, factored, and then reduced \
modulo 9.
This function is intended to check a related local congruence condition at p \
= 3.
Condition P5 in Papadopoulus\[CloseCurlyQuote]paper for p=3 (Section II.2, \
Tableaus II)\
\>", "Text",
 CellChangeTimes->{
  3.990668495850008*^9, {3.990668608689356*^9, 3.990668629771914*^9}, {
   3.990672631848387*^9, 3.990672635188414*^9}, 3.990672703406727*^9, {
   3.9906727651735888`*^9, 
   3.990672766140173*^9}},ExpressionUUID->"f640252a-8b13-424d-a5d8-\
fe5c738475ec"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CuentaP5", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c6", "/", 
            RowBox[{"3", "^", "6"}]}], ")"}], "^", "2"}], "+", "2", "-", 
         RowBox[{"3", " ", 
          RowBox[{"c4", "/", 
           RowBox[{"3", "^", "4"}]}]}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"3", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "9"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.99067240018237*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"9f4950d3-a8b0-460b-a982-650aaec4db9c"]
}, Closed]],

Cell[CellGroupData[{

Cell["PolandLemma22", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, 
   3.990667946386627*^9},ExpressionUUID->"88357dfd-c8d7-4f96-bac7-\
0bd8c3163e4e"],

Cell["\<\
PolandLemma22[c6, m, n]
Computes c6/2^n after the substitution t = 2^m u.
The expression is power - expanded, refined, factored, and reduced modulo 4.
This appears to be designed to verify a congruence condition related to Lemma \
2.2 in Browkin & Davies\[CloseCurlyQuote] paper.\
\>", "Text",
 CellChangeTimes->{
  3.990668499775419*^9, {3.990668633753881*^9, 3.990668643091579*^9}, {
   3.9906727441943703`*^9, 
   3.99067275898619*^9}},ExpressionUUID->"9f6d3885-41cf-44d3-9e0d-\
e1da0ede59cf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PolandLemma22", "[", 
   RowBox[{"c6_", ",", "m_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{"c6", "/", 
         RowBox[{"2", "^", "n"}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"2", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "4"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.886303098200499*^9, 3.886303176740327*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"f2473d0b-a13c-4e3a-821d-8dafc9be617f"]
}, Closed]],

Cell[CellGroupData[{

Cell["Vision", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, 
   3.990667957557056*^9, {3.99067246543884*^9, 
   3.990672466608118*^9}},ExpressionUUID->"16de7b78-964c-4de8-966d-\
e34156448229"],

Cell["\<\
Vision[P, u]
Factors the polynomial or expression P.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
 This is a diagnostic helper function for inspecting the coefficients of the \
factors of P.
  The function uses FactorList, which is safer than applying List directly to \
Factor[P], because it avoids splitting irreducible sums into terms.\
\>", "Text",
 CellChangeTimes->{
  3.990668503318449*^9, {3.9906686471060133`*^9, 3.9906686674900217`*^9}, {
   3.990672476810256*^9, 
   3.990672477733142*^9}},ExpressionUUID->"012410d1-895e-4a63-aa2d-\
93f10ef125a0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Vision", "[", 
   RowBox[{"P_", ",", "u_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"L", "=", 
     RowBox[{"Factor", "[", "P", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "<=", 
       RowBox[{"Length", "@", "L"}]}], ",", 
      RowBox[{"i", "++"}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"i", ",", "\"\< <---> \>\"", ",", 
         RowBox[{"L", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", " ", 
       RowBox[{"Print", "@", 
        RowBox[{"MatrixForm", "@", 
         RowBox[{"Transpose", "@", 
          RowBox[{"{", 
           RowBox[{"CoefficientList", "[", 
            RowBox[{
             RowBox[{"L", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", "u"}], "]"}], 
           "}"}]}]}]}]}]}], "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886401267026865*^9, 3.8864012679454947`*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"9c0173ff-c211-4daf-bb3e-af2742f63e83"]
}, Closed]],

Cell[CellGroupData[{

Cell["VisionMod", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990672485630422*^9, 
   3.990672486506579*^9}},ExpressionUUID->"0809d27e-ee6f-490b-83e7-\
d401dfde9fb3"],

Cell["\<\
AyudaMod[P, u, p]
First reduces P modulo p and factors the result.
For each non - constant factor, it prints :
  - the index of the factor,
  - the factor itself,
  - the coefficient list of the factor with respect to the variable u.
This is useful for studying the factorization and coefficients of P modulo p.\
\
\>", "Text",
 CellChangeTimes->{
  3.990668506896264*^9, {3.990668672078745*^9, 
   3.990668680314468*^9}},ExpressionUUID->"acae1bf0-6a4e-4413-9487-\
dfd50ed2dbd8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"VisionMod", "[", 
   RowBox[{"P_", ",", " ", "u_", ",", " ", "p_"}], "]"}], " ", ":=", "\n", 
  "  ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"L", ",", " ", "Q", ",", " ", "i"}], "}"}], ",", "\n", "    ", 
    RowBox[{
     RowBox[{"Q", " ", "=", " ", 
      RowBox[{"PolynomialMod", "[", 
       RowBox[{"P", ",", " ", "p"}], "]"}]}], ";", "\n", "    ", 
     RowBox[{"L", " ", "=", " ", 
      RowBox[{
       RowBox[{"FactorList", "[", "Q", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"2", " ", ";;"}], ",", " ", "1"}], "]"}], "]"}]}], ";", "\n",
      "    ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"L", " ", "===", " ", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"L", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{"Factor", "[", "Q", "]"}], "}"}]}]}], "  ", "]"}], ";", "\n",
      "    ", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", " ", "=", " ", "1"}], ",", " ", 
       RowBox[{"i", " ", "<=", " ", 
        RowBox[{"Length", "[", "L", "]"}]}], ",", " ", 
       RowBox[{"i", "++"}], ",", "  ", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"i", ",", " ", "\"\< <---> \>\"", ",", " ", 
          RowBox[{"L", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", " ", "@", " ", 
         RowBox[{"MatrixForm", " ", "@", " ", 
          RowBox[{"Transpose", " ", "@", " ", 
           RowBox[{"{", 
            RowBox[{"CoefficientList", "[", 
             RowBox[{
              RowBox[{"L", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", " ", "u"}], "]"}], 
            "}"}]}]}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], 
   "\[IndentingNewLine]", " ", "]"}]}]], "Input",
 CellChangeTimes->{{3.9906724917628393`*^9, 3.990672529367728*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"ece02c13-ace7-4c60-a264-e6352678ab22"]
}, Closed]],

Cell[CellGroupData[{

Cell["powerPrime", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, 
   3.990668002047792*^9},ExpressionUUID->"b20a0125-6bed-4aca-9cc4-\
5697fca9c7a9"],

Cell["\<\
powerPrime[n, p]
Computes the exponent of the prime p in the prime factorization of n.
 In other words, it returns the p - adic valuation v_p (n).\
\>", "Text",
 CellChangeTimes->{
  3.990668512216362*^9, {3.990668685634695*^9, 
   3.990668705264998*^9}},ExpressionUUID->"361ead23-225f-4c75-b09a-\
2bd864d53e21"],

Cell[BoxData[
 RowBox[{
  RowBox[{"powerPrime", "[", 
   RowBox[{"n_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "f", "}"}], ",", 
    RowBox[{
     RowBox[{"f", "=", 
      RowBox[{"FactorInteger", "[", "n", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"k", "=", 
      RowBox[{"Cases", "[", 
       RowBox[{"f", ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"p", ",", "k_"}], "}"}], "\[RuleDelayed]", "k"}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"k", "\[Equal]", 
        RowBox[{"{", "}"}]}], ",", "0", ",", 
       RowBox[{"k", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8872517996742373`*^9, 3.887251812890751*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"4ea933eb-bf13-499a-a135-711cb356ba39"]
}, Closed]],

Cell[CellGroupData[{

Cell["pIntegralModel", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990668014657935*^9, 
   3.990668018277915*^9}},ExpressionUUID->"b0b0bde7-0a56-42a6-b1d0-\
9c2c61c4dc8a"],

Cell["\<\
pIntegralModel[M, p]
Checks whether the Weierstrass coefficients associated to the invariant \
triple M are p - integral.
The input M is expected to be a list of the form
      M = {c4, c6, Delta}.
The corresponding Weierstrass coefficients are computed as
    a4 = -M[[1]]/48,
    a6 = -M[[2]]/864.
 The function then checks whether the denominators of a4 and a6 are divisible \
by p.
 It returns True if both coefficients are p - integral.
 If at least one coefficient is not p - integral, it prints {a4, a6} and \
returns False.\
\>", "Text",
 CellChangeTimes->{
  3.990668515099354*^9, {3.990668711294724*^9, 
   3.990668748113006*^9}},ExpressionUUID->"965afc88-14f3-4cf4-9481-\
1ec28ae14fd0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pIntegralModel", "[", 
   RowBox[{"M_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"F", ",", "L"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"F", "=", 
      RowBox[{"Factor", "@", 
       RowBox[{"Refine", "@", 
        RowBox[{"PowerExpand", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{"M", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], "/", "48"}], ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"M", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "/", "864"}]}], "}"}], 
         "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"L", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"powerPrime", "[", 
         RowBox[{
          RowBox[{"Denominator", "@", 
           RowBox[{"F", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", "p"}], "]"}], ",", 
        RowBox[{"powerPrime", "[", 
         RowBox[{
          RowBox[{"Denominator", "@", 
           RowBox[{"F", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", "p"}], "]"}]}], "}"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"L", "\[Equal]", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], ",", "True", ",", " ", 
       RowBox[{
        RowBox[{"Print", "[", "L", "]"}], ";", "False"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.8872080410140142`*^9, 3.8872081043152437`*^9}, {
  3.887208226545286*^9, 3.887208239810857*^9}, {3.887208283031227*^9, 
  3.887208385892682*^9}, {3.8872514232683887`*^9, 3.887251491833002*^9}, {
  3.887251557834517*^9, 3.8872515674537363`*^9}, {3.887251831685504*^9, 
  3.8872518580315332`*^9}, {3.887251912020729*^9, 3.8872520142963457`*^9}, {
  3.887252068933837*^9, 3.887252093188457*^9}, {3.887252292695537*^9, 
  3.887252335330195*^9}, {3.9906725807675543`*^9, 3.9906725819134483`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"97f6f90f-f7c3-44ce-ad6c-f05a26e12498"]
}, Closed]],

Cell[CellGroupData[{

Cell["aInvariants", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 3.9906679078802147`*^9}, {
   3.990667957557056*^9, 3.9906679717964983`*^9}, {3.990668014657935*^9, 
   3.990668018277915*^9}, 
   3.991049666438471*^9},ExpressionUUID->"ff575183-a67b-498c-b30f-\
d8d868396e84"],

Cell["\<\
aInvariants[c4,c6]
Given the c-invariants c4 and c6 of an elliptic curve E,   
this function returns the corresponding coefficients {a4, a6}  of the short \
Weierstrass equation 
  y^2 = x^3 + a4 x + a6
using the relations
   a4 = -c4/48,
   a6 = -c6/864.\
\>", "Text",
 CellChangeTimes->{
  3.990668515099354*^9, {3.990668711294724*^9, 3.990668748113006*^9}, {
   3.991049684125448*^9, 3.991049688373836*^9}, {3.99104991174494*^9, 
   3.9910500573305283`*^9}, {3.991050235804418*^9, 
   3.991050278812703*^9}},ExpressionUUID->"356f1381-4651-4f1f-9405-\
67f6ddcf0a49"],

Cell[BoxData[
 RowBox[{
  RowBox[{"aInvariants", "[", 
   RowBox[{"c4_", ",", "c6_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "c4"}], "/", "48"}], ",", 
    RowBox[{
     RowBox[{"-", "c6"}], "/", "864"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.991049681538488*^9, 3.991049758442471*^9}, {
  3.9910500946855*^9, 3.9910500974481287`*^9}, {3.991050241722801*^9, 
  3.991050245677408*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"6a4d573d-b7fe-42d9-8d02-22297a30266c"]
}, Closed]]
}, Closed]],

