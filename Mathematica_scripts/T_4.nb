}, Closed]],

Cell[CellGroupData[{

Cell["SpecificPowerPrint", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, 
   3.990667884593225*^9},ExpressionUUID->"9847763f-6d16-48bd-bb52-\
13858eaa9365"],

Cell["\<\
SpecificPowerPrint[c4, c6, Delta, p, m]
Replaces t by p^m*u for a specified exponent m.
It prints the associated Weierstrass coefficients
    a4 = -c4/48,
    a6 = -c6/864,
and returns the transformed and factored triple {c4, c6, Delta}.\
\>", "Text",
 CellChangeTimes->{
  3.990668485703532*^9, {3.990668559439372*^9, 
   3.9906685680455847`*^9}},ExpressionUUID->"f463d711-c0a0-4d37-a5d5-\
cb961cdfddae"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SpecificPowerPrint", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "Delta_", ",", "p_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"Factor", "@", 
      RowBox[{"Refine", "@", 
       RowBox[{"PowerExpand", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"c4", ",", "c6", ",", "Delta"}], "}"}], "/.", 
         RowBox[{"t", "\[Rule]", 
          RowBox[{
           RowBox[{"p", "^", "m"}], "*", "u"}]}]}], "]"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<c4=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "/", "48"}]}], ",", 
       RowBox[{"\"\<c6=\>\"", "-", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "/", "864"}]}]}], "}"}], "]"}], ";",
     "\[IndentingNewLine]", " ", 
    RowBox[{"Return", "[", "M", "]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.886304183922884*^9, 3.886304218856881*^9}, {
  3.8864242640941772`*^9, 3.886424274426693*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"82d9af06-eed3-445f-9c36-d3a8e2373d51"]
}, Closed]],

Cell[CellGroupData[{

Cell["Twist", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.9906679078802147`*^9}},ExpressionUUID->"93283046-048d-425b-94c9-\
92c29f3bf5c1"],

Cell["\<\
Twist[{c4, c6, Delta}, s]
 Applies the standard scaling transformation to the invariants of an elliptic \
curve.
 Under a change of variables with scaling factor s, the invariants transform as
    c4    -> c4/s^4,
    c6    -> c6/s^6,
    Delta -> Delta/s^12.
 The resulting expressions are power - expanded, refined, and factored.\
\>", "Text",
 CellChangeTimes->{
  3.9906684897516203`*^9, {3.9906685763156033`*^9, 
   3.99066859000504*^9}},ExpressionUUID->"2b59db68-3e06-46c2-ad0f-\
c89110928c9a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Twist", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"c4_", ",", "c6_", ",", "Delta_"}], "}"}], ",", "s_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"PowerExpand", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"c4", "/", 
        RowBox[{"s", "^", "4"}]}], ",", 
       RowBox[{"c6", "/", 
        RowBox[{"s", "^", "6"}]}], ",", 
       RowBox[{"Delta", "/", 
        RowBox[{"s", "^", "12"}]}]}], "}"}], "]"}], "//", "Refine"}], "//", 
   "Factor"}]}]], "Input",
 CellChangeTimes->{{3.8862536998964443`*^9, 3.886253769114563*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"91201351-9fa9-4f56-8834-e957b0455cb0"]
}, Closed]],

Cell[CellGroupData[{

Cell["CuentaP2 ", "Subsubsection",
 CellChangeTimes->{{3.990667463527824*^9, 3.990667472608206*^9}, 
   3.990667773024621*^9, {3.990667884593225*^9, 
   3.9906679276567574`*^9}},ExpressionUUID->"e15a8262-c076-4cad-ad14-\
cae2e874705d"],

Cell["\<\
CuentaP2[c4, c6, m]
Computes the congruence expression
   (c6/3^3)^2 + 2 - 3 c4/3^2
after the substitution t = 3^m u.
The expression is power - expanded, refined, factored, and then reduced \
modulo 9.
This function is intended to check a local congruence condition at p = 3.\
\[LineSeparator]Condition P2 in Papadopoulus\[CloseCurlyQuote]s paper for p=3 \
(Section II.2, Tableaus II)\
\>", "Text",
 CellChangeTimes->{{3.990668254622575*^9, 3.990668255780031*^9}, 
   3.990668492990816*^9, {3.990668598544017*^9, 3.990668605585143*^9}, {
   3.990672598122566*^9, 3.990672625986929*^9}, {3.990672681549316*^9, 
   3.990672696935503*^9}, {3.990672770157649*^9, 
   3.990672775668046*^9}},ExpressionUUID->"158af679-5493-4d99-9a4e-\
98a0fbdc5738"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CuentaP2", "[", 
   RowBox[{"c4_", ",", "c6_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"PolynomialMod", "[", 
   RowBox[{
    RowBox[{"Factor", "@", 
     RowBox[{"Refine", "@", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c6", "/", 
            RowBox[{"3", "^", "3"}]}], ")"}], "^", "2"}], "+", "2", "-", 
         RowBox[{"3", " ", 
          RowBox[{"c4", "/", 
           RowBox[{"3", "^", "2"}]}]}]}], "/.", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{
          RowBox[{"3", "^", "m"}], "*", "u"}]}]}], "]"}]}]}], ",", "9"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.990672383534123*^9},
 CellLabel->"In[8]:=",ExpressionUUID->"7ef34057-aea7-4798-9b91-6f73da8ec302"]
}, Closed]],

Cell[CellGroupData[{

Cell["CuentaP5", "Subsubsection",
