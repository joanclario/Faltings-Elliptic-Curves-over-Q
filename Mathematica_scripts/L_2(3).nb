Cell[TextData[{
 "t=1+4a\n t+27=4(7+a) --> m=",
 Cell[BoxData[
  SubscriptBox["\[Nu]", "2"]],
  CellChangeTimes->{3.886252756526535*^9},ExpressionUUID->
  "423b6f41-8aa9-4335-908c-e5d632e762e0"],
