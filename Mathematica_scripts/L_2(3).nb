  SubscriptBox["\[Nu]", "2"]],
  CellChangeTimes->{3.886252756526535*^9},ExpressionUUID->
  "f910e3dc-358b-4af8-9d63-1166ad6d4bed"],
 "(a+7)=m-2\n t+243= 4(61+a)  --> n=",
 Cell[BoxData[
  SubscriptBox["\[Nu]", "2"]],
  CellChangeTimes->{3.886252756526535*^9},ExpressionUUID->
  "445370f5-9fe2-46b9-b74b-2893737bceb1"],
